---
import Layout from '~/layouts/PageLayout.astro';
import SchemaOrg from '~/components/common/SchemaOrg.astro';
import Hero from '~/components/widgets/Hero.astro';
import ProductShowcase from '~/components/widgets/ProductShowcase.astro';
import SoftwareVsService from '~/components/widgets/SoftwareVsService.astro';
import BuiltForCAHs from '~/components/widgets/BuiltForCAHs.astro';
import ScheduleStability from '~/components/widgets/ScheduleStability.astro';
import WeeklyPackage from '~/components/widgets/WeeklyPackage.astro';
import QualityChecks from '~/components/widgets/QualityChecks.astro';
import WeeklyCadence from '~/components/widgets/WeeklyCadence.astro';
import CalloutDetail from '~/components/widgets/CalloutDetail.astro';
import FounderSection from '~/components/widgets/FounderSection.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'SimpleScheduleAI - Assisted Nurse Scheduling for Critical Access Hospitals',
  description:
    'Scheduling stress drives your best nurses out and burns your budget. We deliver a compliant, post-ready schedule every week, with automatic callout coverage.',
  ignoreTitleTemplate: true,
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SimpleScheduleAI',
  url: 'https://simplescheduleai.com',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does SimpleScheduleAI handle last-minute nurse callouts?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'When a nurse calls out, SimpleScheduleAI instantly generates a replacement shortlist from available, qualified staff, factoring in overtime rules, fairness, and Texas compliance. The nurse manager receives the list and can notify replacements directly, reducing coverage time from hours to minutes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is SimpleScheduleAI compliant with Texas nurse staffing regulations?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. SimpleScheduleAI tracks Texas state overtime rules and federal staffing guidelines for critical access hospitals, flagging compliance issues before the schedule is published. An audit trail log is maintained for regulatory review.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does implementation look like for a 25-bed hospital?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Onboarding for a typical 25-bed critical access hospital takes less than a week. The nurse manager uploads the existing roster via Excel, configures shift rules and preferences, and SimpleScheduleAI generates the first draft schedule for review. No complex IT integration is required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does it take to get started?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most critical access hospitals are up and running within 3–5 business days. The process involves uploading your nurse roster in Excel format, setting shift rules, and reviewing the first AI-generated schedule. Our team handles configuration support throughout onboarding.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can SimpleScheduleAI replace our existing scheduling spreadsheets?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. SimpleScheduleAI is designed to replace manual Excel scheduling for critical access hospitals. It accepts Excel roster uploads, so there is no need to rebuild your nurse database from scratch, and schedule outputs can be exported for staff distribution.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the ROI for a critical access hospital using SimpleScheduleAI?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Critical access hospitals using SimpleScheduleAI typically see 12–18% operational efficiency improvement in Year 1, up to 30% reduction in overtime costs through predictive scheduling, and 12% reduction in agency staffing reliance within 6 months. Nurse manager administrative time drops by 15–28%.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is our staff data protected?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'SimpleScheduleAI does not store patient data. All scheduling data is encrypted at rest (AES-256) and in transit (TLS 1.3). SimpleScheduleAI does not share staff data with third parties and maintains data handling practices aligned with healthcare privacy requirements.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens if a nurse declines a shift offered through the system?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'If a nurse declines, SimpleScheduleAI automatically moves to the next ranked candidate on the replacement shortlist. The manager sees the full ranked list and can work through it sequentially until coverage is confirmed. All actions are logged in the audit trail.',
      },
    },
  ],
};
---

<Layout metadata={metadata}>
  <SchemaOrg slot="head" schema={[webSiteSchema, faqSchema]} />
  <!-- Hero Section -->
  <Hero
    announcement="3 CAH pilot spots open. Full managed service, free for 60 days."
    tagline="For Nurse Managers and DONs at Critical Access Hospitals in Texas"
    actions={[
      {
        variant: 'primary',
        text: 'Claim a Pilot Spot',
        href: '/contact',
      },
      {
        variant: 'secondary',
        text: 'See How It Works',
        href: '/how-it-works',
      },
    ]}
  >
    <Fragment slot="title"> Stop losing nurses to scheduling stress. </Fragment>

    <Fragment slot="subtitle">
      No more Sunday evenings rebuilding the roster. No more hunting for a replacement when someone calls out. We
      deliver a compliant, post-ready schedule every cycle, with automatic callout coverage.
    </Fragment>
  </Hero>

  <!-- Product Interface Showcase -->
  <ProductShowcase />

  <!-- Software vs Service Comparison -->
  <SoftwareVsService />

  <!-- Built for CAHs -->
  <BuiltForCAHs />

  <!-- Schedule Stability -->
  <ScheduleStability />

  <!-- Weekly Package -->
  <WeeklyPackage />

  <!-- Quality Checks -->
  <QualityChecks />

  <!-- Weekly Cadence -->
  <WeeklyCadence />

  <!-- Callout Detail -->
  <CalloutDetail />

  <!-- Founder Section -->
  <FounderSection />

  <!-- FAQ -->
  <FAQs
    title="Frequently Asked Questions"
    tagline="Common questions"
    items={[
      {
        title: 'How long does it take to get started?',
        description:
          'Under two weeks. You send us your staff list and shift structure via Excel. We configure the rules, run a test cycle, and hand you a draft schedule for review. No IT involvement required.',
      },
      {
        title: 'Do my nurses need to create accounts or download anything?',
        description: "No. Your staff never touches the software. You get a PDF and Excel file by Thursday. That's it.",
      },
      {
        title: 'What if we already have a scheduling system?',
        description:
          "Most of our pilots come from teams using spreadsheets or a basic tool that doesn't enforce rules. We don't replace your EMR. We deliver the schedule so you don't have to build it.",
      },
      {
        title: 'How do you handle our unit-specific rules?',
        description:
          'We configure them before your first cycle. Charge nurse requirements, skill mix ratios, on-call limits: all mapped to your unit. Changes take effect the next cycle.',
      },
      {
        title: "Who do we contact when there's a call-out at 2AM?",
        description:
          "The system auto-generates replacement candidates as soon as a call-out is logged. You get the top 3 with reasons. One click to approve. You don't have to call us, but we're reachable if something unusual comes up.",
      },
    ]}
  />

  <!-- Call to Action -->
  <CallToAction
    title="A compliant, post-ready schedule every cycle.<br/>Free for 60 days."
    subtitle="3 pilot spots open. No IT setup. No strings attached."
    tagline="Limited availability"
    actions={[
      {
        variant: 'primary',
        text: 'Claim a Pilot Spot',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="content">
      <ul class="mt-4 space-y-3 text-left">
        <li class="flex items-start gap-3">
          <span class="mt-1 shrink-0 text-blue-400 dark:text-blue-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
          <span class="text-lg leading-relaxed text-gray-300"
            >A compliant, post-ready schedule delivered every week</span
          >
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 shrink-0 text-blue-400 dark:text-blue-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
          <span class="text-lg leading-relaxed text-gray-300"
            >Call-out replacement candidates, ready to approve in one click</span
          >
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 shrink-0 text-blue-400 dark:text-blue-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
          <span class="text-lg leading-relaxed text-gray-300"
            >A weekly manager summary: what changed, budget impact, pending approvals</span
          >
        </li>
      </ul>

      <p class="mt-6 text-pretty text-base leading-relaxed text-gray-400">
        After 60 days, if your team did not save real scheduling time, we part ways. No invoice. No contract. The pilot
        is entirely at our cost.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
        <span
          class="inline-flex items-center gap-x-1.5 rounded-full border border-blue-800/50 bg-blue-900/30 px-3 py-1.5 text-xs font-medium text-blue-300"
          >Free for 60 Days</span
        >
        <span
          class="inline-flex items-center gap-x-1.5 rounded-full border border-blue-800/50 bg-blue-900/30 px-3 py-1.5 text-xs font-medium text-blue-300"
          >3 Hospitals Only</span
        >
        <span
          class="inline-flex items-center gap-x-1.5 rounded-full border border-blue-800/50 bg-blue-900/30 px-3 py-1.5 text-xs font-medium text-blue-300"
          >Full Managed Service</span
        >
        <span
          class="inline-flex items-center gap-x-1.5 rounded-full border border-blue-800/50 bg-blue-900/30 px-3 py-1.5 text-xs font-medium text-blue-300"
          >No IT Setup</span
        >
        <span
          class="inline-flex items-center gap-x-1.5 rounded-full border border-blue-800/50 bg-blue-900/30 px-3 py-1.5 text-xs font-medium text-blue-300"
          >First Schedule in Under 2 Weeks</span
        >
      </div>
    </Fragment>
  </CallToAction>
</Layout>
