---
import Layout from '~/layouts/PageLayout.astro';
import ContactForm from '~/components/ui/forms/ContactForm.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Contact SimpleScheduleAI',
  description: 'Talk to a human. We respond fast. If you want, we will send a one page pilot overview.',
};

const contactDetails = {
  location: 'Remote, US',
  email: 'support@simplescheduleai.com',
};

const ctaLink = 'https://cal.com/gautham-8bdvdx/30min';
---

<Layout metadata={metadata}>
  <!-- Form + details -->
  <section class="bg-page">
    <div class="mx-auto max-w-7xl px-4 pt-28 pb-16 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">Talk to us</p>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-3">Contact</h1>
        <p class="text-lg text-muted max-w-2xl">{metadata.description}</p>
      </div>
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
        <div
          class="rounded-3xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 shadow-sm sm:p-8"
        >
          <div class="mb-5">
            <h2 class="text-xl font-semibold">Get the pilot details</h2>
            <p class="mt-2 text-default">
              Leave your email and we will send a one page overview. If you are not a fit, we will tell you quickly.
            </p>
          </div>

          <div class="rounded-2xl bg-blue-100 dark:bg-blue-950/30 p-4 sm:p-5">
            <ContactForm />
          </div>

          <p class="mt-4 text-sm text-muted">No spam. No software rollout. Excel is fine.</p>
        </div>

        <div
          class="rounded-3xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 shadow-sm sm:p-8"
        >
          <h2 class="text-xl font-semibold">Contact details</h2>
          <p class="mt-2 text-default">
            If you prefer, email us and include a sample schedule format or a description of your constraints.
          </p>

          <div class="mt-6 space-y-5">
            <div class="flex gap-x-4">
              <Icon name="tabler:map-pin" class="mt-0.5 w-6 h-6 shrink-0 text-primary" />
              <div class="grow">
                <p class="font-semibold">Location</p>
                <p class="text-sm text-default">{contactDetails.location}</p>
              </div>
            </div>

            <div class="flex gap-x-4">
              <Icon name="tabler:calendar" class="mt-0.5 w-6 h-6 shrink-0 text-primary" />
              <div class="grow">
                <p class="font-semibold">Book a Call</p>
                <a
                  class="text-sm text-default underline decoration-gray-300 dark:decoration-gray-600 underline-offset-4 transition-colors hover:text-primary"
                  href={ctaLink}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Schedule a 30-minute call
                </a>
              </div>
            </div>

            <div class="flex gap-x-4">
              <Icon name="tabler:mail" class="mt-0.5 w-6 h-6 shrink-0 text-primary" />
              <div class="grow">
                <p class="font-semibold">Email</p>
                <a
                  class="text-sm text-default underline decoration-gray-300 dark:decoration-gray-600 underline-offset-4 transition-colors hover:text-primary"
                  href={`mailto:${contactDetails.email}`}
                >
                  {contactDetails.email}
                </a>
              </div>
            </div>
          </div>

          <div class="mt-8 rounded-2xl border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950/30 p-5">
            <p class="text-sm font-semibold text-blue-800 dark:text-blue-300">What to include in your message</p>
            <ul class="mt-3 space-y-2">
              {
                [
                  'Unit size and shift pattern (12h, 8h, mixed)',
                  'How schedules are built today (Excel, paper, vendor tool)',
                  'Rules that cause the most pain (coverage, overtime, fairness, time off)',
                  'How often you publish schedules (weekly, biweekly, monthly)',
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary" />
                    <span class="text-sm text-default">{item}</span>
                  </li>
                ))
              }
            </ul>
            <p class="mt-4 text-sm text-muted">
              We will reply with a simple next step and a clear timeline for the pilot.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const textarea = document.querySelector('#input-message');
      if (!textarea) return;

      const resize = (offsetTop = 0) => {
        textarea.style.height = 'auto';
        textarea.style.height = `${textarea.scrollHeight + offsetTop}px`;
      };

      resize(3);
      textarea.addEventListener('input', () => resize(3));
    });
  </script>
</Layout>
