---
import Layout from '~/layouts/PageLayout.astro';
import SchemaOrg from '~/components/common/SchemaOrg.astro';

const metadata = {
  title: 'Pradeep Pandey — Co-Founder, SimpleScheduleAI',
  description:
    'Pradeep Pandey is the co-founder of SimpleScheduleAI. Deputy General Manager of Operations, Apollo Hospitals, he builds AI-assisted scheduling for Critical Access Hospitals in Texas.',
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://simplescheduleai.com/about/pradeep-pandey#person',
  name: 'Pradeep Pandey',
  givenName: 'Pradeep',
  familyName: 'Pandey',
  url: 'https://simplescheduleai.com/about/pradeep-pandey',
  image: 'https://simplescheduleai.com/founders/pradeep.webp',
  jobTitle: 'Co-Founder',
  description:
    'Co-founder of SimpleScheduleAI. Deputy General Manager of Operations, Apollo Hospitals. Builds AI-assisted nurse scheduling for Critical Access Hospitals in Texas.',
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://simplescheduleai.com/#organization',
    name: 'SimpleScheduleAI',
  },
  affiliation: [
    {
      '@type': 'Organization',
      name: 'Apollo Hospitals',
      url: 'https://www.apollohospitals.com',
    },
  ],
  knowsAbout: [
    'Nurse scheduling',
    'Hospital operations management',
    'Healthcare S&OP and process reengineering',
    'Critical Access Hospital operations',
    'Texas nursing overtime compliance',
    'CMS §485.635 staffing documentation',
    'AI-assisted workforce management',
    'Healthcare workforce management',
    'Hospital scheduling software',
    'Digital transformation in healthcare',
  ],
  sameAs: [
    'https://www.linkedin.com/in/pradeep-pandeyji/',
    'https://www.crunchbase.com/person/pradeep-pandey',
    'https://www.g2.com/users/pradeep-pandey',
  ],
};

const topics = [
  'Nurse scheduling for Critical Access Hospitals',
  'Texas nursing overtime and CMS compliance',
  'Callout coverage and fair rotation design',
  'AI-assisted scheduling vs. traditional software',
  'Hospital workforce management for small and rural hospitals',
];
---

<Layout metadata={metadata}>
  <SchemaOrg slot="head" schema={[personSchema]} />

  <section class="py-12 sm:py-20 mx-auto max-w-3xl px-4 sm:px-6">
    <!-- Author header -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-12">
      <img
        src="/founders/pradeep.webp"
        alt="Pradeep Pandey, Co-Founder of SimpleScheduleAI"
        class="h-28 w-28 rounded-full object-cover ring-4 ring-blue-100 dark:ring-blue-900 shrink-0"
        width="112"
        height="112"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Pradeep Pandey</h1>
        <p class="mt-1 text-lg font-semibold text-primary">Co-Founder, SimpleScheduleAI</p>
        <p class="mt-0.5 text-sm text-muted dark:text-slate-400">
          Deputy General Manager of Operations, Apollo Hospitals
        </p>
        <a
          href="https://www.linkedin.com/in/pradeep-pandeyji/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:underline"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Bio -->
    <div class="prose dark:prose-invert max-w-none">
      <h2 class="text-xl font-bold mb-4">About</h2>
      <p class="text-muted dark:text-slate-300 leading-relaxed">
        Pradeep Pandey is the co-founder of SimpleScheduleAI and the Deputy General Manager of Operations at Apollo
        Hospitals, where he leads corporate strategy across 19 hospitals in 6 states, optimizing operations for 2,000+
        beds. His work spans process reengineering, digital transformation, and S&OP implementation across business
        units. That experience includes watching, up close, how manual nurse scheduling creates cascading problems:
        overtime spikes, agency dependency, staff burnout, and turnover that no spreadsheet can prevent.
      </p>
      <p class="mt-4 text-muted dark:text-slate-300 leading-relaxed">
        He built SimpleScheduleAI after hours because he saw a gap no one was filling. Large hospital systems have
        enterprise scheduling platforms. Critical Access Hospitals, the small rural facilities that are often the only
        care option for their communities, are left with Excel and sticky notes. SimpleScheduleAI is built specifically
        for them: a managed scheduling service that delivers a compliant, post-ready schedule every cycle, with
        automatic callout coverage and Texas overtime compliance built in.
      </p>
      <p class="mt-4 text-muted dark:text-slate-300 leading-relaxed">
        Before shipping a single feature, Pradeep and his co-founder conducted more than 30 in-depth interviews with
        nurse managers and CNOs at Critical Access Hospitals across Texas. Not surveys. Real conversations about real
        scheduling problems. Those conversations shaped every design decision: credential-filtered callout replacement,
        automated CMS §485.635 documentation, and a delivery format (PDF and Excel) that requires no software rollout
        for nursing staff.
      </p>
      <p class="mt-4 text-muted dark:text-slate-300 leading-relaxed">
        He writes about nurse scheduling, CAH operations, hospital workforce management, and what it actually takes to
        keep a 25-bed hospital staffed safely without burning out the people running it.
      </p>
    </div>

    <!-- Topics -->
    <div class="mt-10">
      <h2 class="text-xl font-bold mb-4">Topics Covered</h2>
      <ul class="space-y-2">
        {
          topics.map((topic) => (
            <li class="flex items-start gap-2 text-muted dark:text-slate-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 mt-0.5 text-primary shrink-0"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
              {topic}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contact / CTA -->
    <div class="mt-12 rounded-xl border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950/30 px-6 py-6">
      <h2 class="text-lg font-bold mb-2">Work with SimpleScheduleAI</h2>
      <p class="text-muted dark:text-slate-300 text-sm leading-relaxed mb-4">
        SimpleScheduleAI runs a 60-day free pilot for Critical Access Hospitals in Texas. No IT setup. No contract. The
        first schedule ships in under two weeks.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-secondary transition-colors"
      >
        Claim a Pilot Spot
      </a>
    </div>

    <!-- Back to blog -->
    <div class="mt-10">
      <a href="/blog" class="text-sm text-muted hover:underline">&larr; Back to all articles</a>
    </div>
  </section>
</Layout>
