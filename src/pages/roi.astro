---
import Layout from '~/layouts/PageLayout.astro';
import SchemaOrg from '~/components/common/SchemaOrg.astro';
import DarkHero from '~/components/widgets/DarkHero.astro';
import ROISection from '~/components/widgets/ROISection.astro';

const metadata = {
  title: 'Scheduling Cost Calculator',
  description:
    "Calculate what nurse scheduling is really costing your Critical Access Hospital in Texas. Adjust sliders to match your hospital's size and see your hidden scheduling costs.",
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Scheduling Cost Calculator',
  description: metadata.description,
  url: 'https://simplescheduleai.com/roi',
  isPartOf: { '@id': 'https://simplescheduleai.com/#organization' },
};

const roiBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://simplescheduleai.com' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Scheduling Cost Calculator',
      item: 'https://simplescheduleai.com/roi',
    },
  ],
};
---

<Layout metadata={metadata}>
  <SchemaOrg slot="head" schema={[webPageSchema, roiBreadcrumbSchema]} />
  <!-- Dark Hero -->
  <DarkHero
    badge="Scheduling Cost Calculator"
    title="What is scheduling really costing you?"
    subtitle="Adjust the sliders to match your hospital. Based on interviews with 30+ nurse managers and published CAH benchmarks."
  />

  <!-- Calculator -->
  <ROISection />

  <!-- CTA -->
  <section class="bg-page pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <a href="/contact" class="btn btn-primary inline-flex px-6 py-3 text-base"> Apply for a Pilot Spot </a>
      <p class="mt-3 text-sm text-muted">Free 60-day pilot. No obligation.</p>
    </div>
  </section>
</Layout>
