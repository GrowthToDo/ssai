---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Make a Warm Intro | SimpleScheduleAI',
  description:
    'Know a nursing manager, hospital admin, or investor? Watch these two short videos and, if this resonates, I would love a warm introduction.',
  robots: { index: false, follow: false },
};

const calLink = 'https://cal.com/gautham-8bdvdx/30min';

// Placeholder YouTube video IDs - swap these when real videos are uploaded
const videoGenericIntro = 'jNQXAC9IVRw';   // Video 1: Generic Warm Intro
const videoProductDemo  = 'dQw4w9WgXcQ';   // Video 2: Detailed Product Demo
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="bg-page">
    <div class="mx-auto max-w-4xl px-4 pt-28 pb-12 sm:px-6 lg:px-8 text-center">
      <span
        class="inline-block mb-5 rounded-full border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950/40 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary"
      >
        Warm Intro Request
      </span>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Can you make an introduction?
      </h1>
      <p class="mt-5 text-lg text-muted max-w-2xl mx-auto">
        I'm building SimpleScheduleAI, AI-powered nurse scheduling for Critical Access Hospitals. Watch
        these two short videos. If you know a nursing manager, hospital admin, or someone who might invest
        in this space, I'd love a warm intro.
      </p>
    </div>
  </section>

  <!-- Videos -->
  <section class="bg-gray-50 dark:bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-2">
        <!-- Video 1 -->
        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 overflow-hidden shadow-sm">
          <div class="aspect-video w-full">
            <iframe
              class="w-full h-full"
              src={`https://www.youtube.com/embed/${videoGenericIntro}`}
              title="SimpleScheduleAI Quick Overview"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-1">Video 1 · 1 min</p>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">The Quick Overview</h2>
            <p class="mt-2 text-muted text-sm">
              What we're building, who it's for, and the three ways you can help, in under a minute.
            </p>
          </div>
        </div>

        <!-- Video 2 -->
        <div class="rounded-3xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 overflow-hidden shadow-sm">
          <div class="aspect-video w-full">
            <iframe
              class="w-full h-full"
              src={`https://www.youtube.com/embed/${videoProductDemo}`}
              title="SimpleScheduleAI Full Product Demo"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-1">Video 2 · 4 min</p>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Full Product Demo</h2>
            <p class="mt-2 text-muted text-sm">
              A live walkthrough of the scheduling engine: callouts, shift swaps, audit trail, and the
              generate-in-under-a-minute experience.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three ways to help -->
  <section class="bg-page">
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Three ways to help</p>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
          Anyone in these categories, we'd love to talk
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 shadow-sm">
          <div class="mb-4 w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
            <Icon name="tabler:user-heart" class="w-5 h-5 text-primary" />
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white">Nursing managers &amp; DONs</h3>
          <p class="mt-2 text-sm text-muted">
            Anyone close to the scheduling problem at a small rural hospital. We want to understand what's working, what
            isn't, and how we can make this better.
          </p>
        </div>

        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 shadow-sm">
          <div class="mb-4 w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
            <Icon name="tabler:building-hospital" class="w-5 h-5 text-primary" />
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white">Hospital administrators</h3>
          <p class="mt-2 text-sm text-muted">
            CAH CEOs and administrators interested in running a free 60-day pilot. We handle the scheduling, you keep
            full control.
          </p>
        </div>

        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-6 shadow-sm">
          <div class="mb-4 w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
            <Icon name="tabler:trending-up" class="w-5 h-5 text-primary" />
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white">Early investors</h3>
          <p class="mt-2 text-muted text-sm">
            We're early and raising. If you invest in healthcare operations or rural health infrastructure, we'd love a
            conversation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / CTA -->
  <section class="bg-slate-950 dark:bg-black">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-400 mb-4">Get in touch</p>
      <h2 class="text-3xl font-bold tracking-tight text-white">
        If you know someone, I'd love to hear from you
      </h2>
      <p class="mt-4 text-gray-400 max-w-xl mx-auto">
        A quick email or a 15-minute call is all it takes. I'll take it from there.
      </p>

      <div class="mt-10 flex flex-col items-center gap-4">
        <div class="flex items-center gap-3 text-lg font-semibold text-white">
          <Icon name="tabler:user" class="w-5 h-5 text-blue-400 shrink-0" />
          <span>Gautham</span>
        </div>
        <a
          href="mailto:gautham@simplescheduleai.com"
          class="flex items-center gap-3 text-lg text-blue-300 hover:text-white transition-colors"
        >
          <Icon name="tabler:mail" class="w-5 h-5 shrink-0" />
          gautham@simplescheduleai.com
        </a>
        <a
          href="tel:+919400474785"
          class="flex items-center gap-3 text-lg text-blue-300 hover:text-white transition-colors"
        >
          <Icon name="tabler:phone" class="w-5 h-5 shrink-0" />
          +91 94004 74785
        </a>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={calLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn text-white border-white/30 hover:bg-white/10 hover:border-white w-full sm:w-auto"
        >
          Or book a 30-min call
        </a>
      </div>
    </div>
  </section>
</Layout>
