---
/**
 * Programmatic SEO route — DORMANT by design.
 *
 * Every generated page ships noindex (metadata.robots.index = false) and is
 * excluded from the sitemap (see astro.config.ts filter). Pages do not enter
 * Google/Bing until an entry in src/data/competitors.json is flipped to
 * status:'live' AND the switch-on criteria in
 * C:/Users/Admin/.claude/plans/lexical-snuggling-liskov.md (section 5) are met,
 * with explicit user go-ahead. scripts/psa-content-gate.mjs hard-fails the
 * build on any thin or unsourced entry, so a thin page cannot ship.
 *
 * No hand-stacked JSON-LD: Organization schema auto-emits from Layout.astro.
 * This route adds only a BreadcrumbList via the existing SchemaOrg slot,
 * matching the pillar pages.
 */
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import SchemaOrg from '~/components/common/SchemaOrg.astro';
import DarkHero from '~/components/widgets/DarkHero.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import competitorsData from '~/data/competitors.json';

export const prerender = true;

export const getStaticPaths = (() => {
  return competitorsData.competitors.map((c) => ({
    params: { competitor: c.slug },
    props: { c },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { c } = Astro.props as Props;

const pageUrl = `https://simplescheduleai.com/alternatives/${c.slug}`;

const metadata = {
  title: `${c.name} Alternatives for Critical Access Hospitals`,
  description: `An honest look at ${c.name} for a 25-bed Critical Access Hospital: where it fits, the clinical-compliance gaps, and how a managed scheduling service compares.`,
  // DORMANT: never index until the entry is flipped live per the switch-on contract.
  robots: { index: false, follow: true },
  canonical: pageUrl,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://simplescheduleai.com' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Alternatives',
      item: 'https://simplescheduleai.com/alternatives',
    },
    { '@type': 'ListItem', position: 3, name: `${c.name} Alternatives`, item: pageUrl },
  ],
};

const ratingLine = [
  c.g2 ? `G2 ${c.g2.rating}/5 (${c.g2.count.toLocaleString()} reviews)` : null,
  c.capterra ? `Capterra ${c.capterra.rating}/5 (${c.capterra.count.toLocaleString()} reviews)` : null,
]
  .filter(Boolean)
  .join(' · ');
---

<Layout metadata={metadata}>
  <SchemaOrg slot="head" schema={breadcrumbSchema} />

  <DarkHero
    badge="Competitor Comparison"
    title={`${c.name} Alternatives for Critical Access Hospitals`}
    subtitle={c.positioning}
    actions={[
      { text: 'Apply for a Pilot Spot', href: '/pilot', variant: 'primary' },
      { text: 'See How It Works', href: '/how-it-works', variant: 'secondary' },
    ]}
  />

  <section class="bg-page py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 prose dark:prose-invert prose-lg max-w-none">
      {
        ratingLine && (
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {c.name} public ratings: {ratingLine}
          </p>
        )
      }

      {c.cahAngle.map((para) => <p>{para}</p>)}

      {
        c.verbatimQuotes.length > 0 && (
          <div class="not-prose my-8 space-y-6">
            {c.verbatimQuotes.map((q) => (
              <blockquote class="border-l-4 border-blue-600 dark:border-blue-400 pl-4">
                <p class="text-slate-700 dark:text-slate-300 italic">"{q.text}"</p>
                <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                  {q.name}, {q.role}, {q.date}, {q.source}
                </p>
              </blockquote>
            ))}
          </div>
        )
      }

      <h2>How {c.name} Compares to SimpleScheduleAI for a 25-Bed Hospital</h2>
      <div class="not-prose my-8 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-300 dark:border-slate-700">
              <th class="p-3 text-left font-semibold text-slate-900 dark:text-slate-100">Dimension</th>
              <th class="p-3 text-left font-semibold text-slate-900 dark:text-slate-100">{c.name}</th>
              <th class="p-3 text-left font-semibold text-blue-700 dark:text-blue-400">SimpleScheduleAI</th>
            </tr>
          </thead>
          <tbody class="text-slate-700 dark:text-slate-300">
            {
              c.comparisonRows.map((row) => (
                <tr class="border-b border-slate-200 dark:border-slate-800 align-top">
                  <td class="p-3 font-medium text-slate-900 dark:text-slate-100">{row.dimension}</td>
                  <td class="p-3">{row.competitor}</td>
                  <td class="p-3">{row.simplescheduleai}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <p>
        For the regulatory and operational context behind this comparison, see our guide to
        <a href="/critical-access-hospital-scheduling">critical access hospital scheduling</a> and the
        <a href="/nurse-scheduling-software">nurse scheduling software</a> overview. For exactly how the managed service
        operates, see <a href="/how-it-works">how it works</a>.
      </p>
    </div>
  </section>

  <FAQs
    title={`${c.name} vs SimpleScheduleAI: Common Questions`}
    items={[
      {
        title: `Is ${c.name} a good fit for a Critical Access Hospital?`,
        description: `${c.name} is ${c.category.toLowerCase()}. For a 25-bed Critical Access Hospital the deciding factor is clinical-compliance and operating-model fit, not product quality. Confirm HIPAA/BAA, CMS 485.635 documentation, and FLSA 8-and-80 handling with the vendor before relying on it for a clinical schedule.`,
      },
      {
        title: `What is the difference between ${c.name} and a managed scheduling service?`,
        description: `${c.name} is software the hospital operates itself; someone on staff configures and runs it weekly. A managed service builds and maintains the schedule and the compliance documentation for the hospital, so the nurse manager reviews and approves a finished schedule instead of operating a tool.`,
      },
    ]}
  />

  <CallToAction
    title="Built for one Critical Access Hospital, not a multi-industry workforce"
    subtitle="Free 60-day managed pilot for Texas CAHs. No IT setup, no platform to operate."
    actions={[
      { variant: 'primary', text: 'Apply for a Pilot Spot', href: '/pilot' },
      { variant: 'secondary', text: 'See How It Works', href: '/how-it-works' },
    ]}
  />
</Layout>
