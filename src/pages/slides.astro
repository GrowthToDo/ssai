    <!-- Nav -->
    <div id="nav">
      <button id="prevBtn" aria-label="Previous slide">&#8592;</button>
      <div class="progress-dots" id="dots"></div>
      <button id="nextBtn" aria-label="Next slide">&#8594;</button>
      <span id="counter">1 / 9</span>
    </div>

    <script>
      const slides = document.querySelectorAll('.slide');
      const total = slides.length;
      let current = 0;

      const dotsContainer = document.getElementById('dots')!;
      const counter = document.getElementById('counter')!;

      // Build dots
      slides.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'dot-nav' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', `Go to slide ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(d);
      });

      function goTo(n) {
        slides[current].classList.remove('active');
        dotsContainer.children[current].classList.remove('active');
        current = Math.max(0, Math.min(n, total - 1));
        slides[current].classList.add('active');
        dotsContainer.children[current].classList.add('active');
        counter.textContent = `${current + 1} / ${total}`;
      }

      document.getElementById('prevBtn')!.addEventListener('click', () => goTo(current - 1));
      document.getElementById('nextBtn')!.addEventListener('click', () => goTo(current + 1));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') {
          e.preventDefault();
          goTo(current + 1);
        }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          goTo(current - 1);
        }
      });

      // Click anywhere on slide to advance (except nav)
      document.getElementById('deck')!.addEventListener('click', () => goTo(current + 1));

      // Scale deck to fit viewport — never exceed 1:1, reserve 80px for nav bar
      function scale() {
        const vw = window.innerWidth,
          vh = window.innerHeight;
        const sw = 1280,
          sh = 720;
        const s = Math.min(1, vw / sw, (vh - 80) / sh) * 0.97;
        document.getElementById('deck')!.style.transform = `scale(${s})`;
      }
      window.addEventListener('resize', scale);
      scale();
    </script>
