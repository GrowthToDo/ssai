---
// Style A: Dark Command — full pitch deck
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SimpleScheduleAI — Pitch Deck</title>
    <meta name="robots" content="noindex" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #05050f;
        --surface: #0a0a1a;
        --surface2: #0f0f22;
        --border: rgba(0, 180, 255, 0.15);
        --accent: #00b4ff;
        --accent2: #7c4dff;
        --green: #00e5a0;
        --red: #ff4d6d;
        --text: #ffffff;
        --muted: rgba(255, 255, 255, 0.42);
        --muted2: rgba(255, 255, 255, 0.22);
      }

      html,
      body {
        width: 100%;
        height: 100%;
        background: #020208;
        overflow: hidden;
        user-select: none;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        color: var(--text);
      }

      /* ── scaler ── */
      #scaler {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      #deck {
        position: relative;
        width: 1280px;
        height: 720px;
        transform-origin: center center;
        overflow: hidden;
      }

      /* ── base slide ── */
      .slide {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        padding: 56px 72px;
        background: var(--bg);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
      }
      .slide.active {
        opacity: 1;
        pointer-events: auto;
      }

      /* grid texture */
      .slide::before {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(0, 180, 255, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 180, 255, 0.035) 1px, transparent 1px);
        background-size: 48px 48px;
      }

      /* corner marks */
      .slide::after {
        content: '';
        position: absolute;
        pointer-events: none;
        top: 20px;
        left: 20px;
        width: 16px;
        height: 16px;
        border-top: 1px solid rgba(0, 180, 255, 0.3);
        border-left: 1px solid rgba(0, 180, 255, 0.3);
      }

      /* ── typography ── */
      .eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .eyebrow::before {
        content: '';
        display: block;
        width: 24px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
      }

      h1 {
        font-size: 62px;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -0.03em;
      }
      h2 {
        font-size: 48px;
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -0.03em;
      }
      .accent {
        color: var(--accent);
      }
      .accent2 {
        color: var(--accent2);
      }
      .green {
        color: var(--green);
      }

      .sub {
        font-size: 16px;
        color: var(--muted);
        line-height: 1.7;
        margin-top: 18px;
      }

      /* divider */
      .div {
        width: 1px;
        background: var(--border);
        align-self: stretch;
      }
      .hdiv {
        height: 1px;
        background: var(--border);
        margin: 20px 0;
      }

      /* card */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 22px 26px;
        position: relative;
      }
      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, var(--accent), transparent);
      }

      /* stat */
      .stat-num {
        font-size: 52px;
        font-weight: 900;
        letter-spacing: -0.04em;
        color: var(--accent);
        line-height: 1;
      }
      .stat-lbl {
        font-size: 12px;
        color: var(--muted);
        margin-top: 6px;
        line-height: 1.5;
      }

      /* grids */
      .g2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }
      .g3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }
      .g4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }

      /* check list */
      .clist {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .clist li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 15px;
        color: var(--text);
        line-height: 1.5;
      }
      .clist li .ck {
        flex-shrink: 0;
        width: 18px;
        height: 18px;
        border-radius: 2px;
        margin-top: 1px;
        background: rgba(0, 180, 255, 0.15);
        border: 1px solid rgba(0, 180, 255, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        color: var(--accent);
      }

      /* step */
      .step-n {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: 8px;
      }
      .step-t {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 6px;
      }
      .step-d {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.55;
      }

      /* pill */
      .pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: rgba(0, 180, 255, 0.08);
        border: 1px solid rgba(0, 180, 255, 0.3);
        color: var(--accent);
      }

      /* VS comparison */
      .vs-wrap {
        display: grid;
        grid-template-columns: 1fr 40px 1fr;
        margin-top: 16px;
      }
      .vs-col {
        padding: 18px 24px;
        background: var(--surface);
        border: 1px solid var(--border);
      }
      .vs-col.left {
        border-radius: 4px 0 0 4px;
        border-right: none;
      }
      .vs-col.right {
        border-radius: 0 4px 4px 0;
        background: rgba(0, 180, 255, 0.06);
        border-color: rgba(0, 180, 255, 0.35);
      }
      .vs-mid {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.15em;
        color: var(--muted2);
        background: var(--bg);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .vs-lbl {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px;
      }
      .vs-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        margin-bottom: 9px;
      }
      .vx {
        color: var(--red);
        font-size: 13px;
      }
      .vck {
        color: var(--green);
        font-size: 13px;
      }

      /* nav */
      #nav {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(5, 5, 15, 0.92);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 8px 16px;
        z-index: 100;
      }
      #nav button {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--muted);
        font-size: 16px;
        padding: 3px 6px;
      }
      #nav button:hover {
        color: var(--text);
      }
      #counter {
        font-size: 11px;
        color: var(--muted);
        min-width: 44px;
        text-align: center;
        letter-spacing: 0.1em;
      }
      .dots {
        display: flex;
        gap: 5px;
        align-items: center;
      }
      .dn {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--border);
        border: none;
        cursor: pointer;
        padding: 0;
        transition: all 0.2s;
      }
      .dn.active {
        background: var(--accent);
        width: 16px;
        border-radius: 2px;
      }

      /* slide-specific */
      #s1 {
        justify-content: center;
      }
      #s1 h1 {
        font-size: 56px;
      }
      #s1 .byline {
        margin-top: 36px;
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }
      #s1 .founder {
        font-size: 13px;
        color: var(--muted);
      }
      #s1 .founder strong {
        color: var(--text);
      }
      .glow {
        position: absolute;
        right: 64px;
        top: 50%;
        transform: translateY(-50%);
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0, 180, 255, 0.1) 0%, transparent 70%);
        border: 1px solid rgba(0, 180, 255, 0.18);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 6px;
      }
      .glow-num {
        font-size: 52px;
        font-weight: 900;
        color: var(--accent);
        letter-spacing: -0.04em;
      }
      .glow-lbl {
        font-size: 12px;
        color: var(--muted);
        line-height: 1.5;
      }

      #s2 .pain-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-top: 24px;
      }
      #s2 .pain-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 22px;
      }
      #s2 .pain-card::before {
        content: '';
        display: block;
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, var(--accent), transparent);
        margin-bottom: 14px;
      }
      #s2 .pain-icon {
        font-size: 22px;
        margin-bottom: 10px;
      }
      #s2 .pain-t {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 8px;
      }
      #s2 .pain-d {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
      }

      #s9 {
        justify-content: center;
        align-items: center;
        text-align: center;
      }
      #s9 .cta-box {
        background: var(--surface);
        border: 1px solid rgba(0, 180, 255, 0.35);
        border-radius: 4px;
        padding: 40px 56px;
        margin-top: 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        position: relative;
      }
      #s9 .cta-box::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
      }
      #s9 .cta-cols {
        display: flex;
        gap: 40px;
        align-items: flex-start;
        text-align: left;
      }
      #s9 .cta-col {
        flex: 1;
      }
      #s9 .cta-lbl {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px;
      }
      #s9 .cta-body {
        font-size: 15px;
        color: var(--text);
        line-height: 1.65;
      }
      #s9 a {
        color: var(--accent);
        text-decoration: none;
        font-size: 16px;
        font-weight: 700;
        display: inline-block;
        margin-top: 14px;
        letter-spacing: -0.01em;
      }
      #s9 .cta-foot {
        font-size: 12px;
        color: var(--muted2);
        margin-top: 24px;
        letter-spacing: 0.05em;
      }

      /* data readout in corner */
      .readout {
        position: absolute;
        right: 72px;
        bottom: 56px;
        font-size: 10px;
        color: var(--muted2);
        letter-spacing: 0.12em;
        font-family: monospace;
      }
    </style>
  </head>
  <body>
    <div id="scaler">
      <div id="deck">
        <!-- S1: Title -->
        <section class="slide active" id="s1">
          <div class="eyebrow">SimpleScheduleAI</div>
          <h1>Nurse Scheduling<br />for <span class="accent">Critical Access</span><br />Hospitals — Solved.</h1>
          <p class="sub">
            An AI-powered managed service that eliminates manual scheduling<br />so CAH administrators can focus on
            running their hospital.
          </p>
          <div class="byline">
            <div class="founder"><strong>Pradeep Pandey</strong> · Founder</div>
            <div class="pill">Texas · 2024</div>
            <div class="pill">Free 60-Day Pilot Open</div>
          </div>
          <div class="glow">
            <div class="glow-num">≤25</div>
            <div class="glow-lbl">beds.<br />Underserved by<br />every tool<br />on the market.</div>
          </div>
          <div class="readout">DECK_v1 · CONFIDENTIAL</div>
        </section>

        <!-- S2: Problem -->
        <section class="slide" id="s2">
          <div class="eyebrow">The Problem</div>
          <h2>CAH Nurse Managers<br />are buried in <span class="accent">scheduling.</span></h2>
          <div class="pain-grid">
            <div class="pain-card">
              <div class="pain-icon">🕐</div>
              <div class="pain-t">8–12 hrs/week — gone</div>
              <div class="pain-d">
                Nurse managers spend a full workday each week juggling spreadsheets, tracking availability, and manually
                enforcing shift rules.
              </div>
            </div>
            <div class="pain-card">
              <div class="pain-icon">⚠️</div>
              <div class="pain-t">Rules get violated</div>
              <div class="pain-d">
                Texas overtime rules, CMS PBJ reporting, charge nurse ratios — manual scheduling misses constraints that
                trigger compliance risk.
              </div>
            </div>
            <div class="pain-card">
              <div class="pain-icon">📞</div>
              <div class="pain-t">Callouts = chaos</div>
              <div class="pain-d">
                A single unexpected callout cascades into hours of calls, texts, and manual rescheduling — every time,
                every shift.
              </div>
            </div>
          </div>
        </section>

        <!-- S3: Market -->
        <section class="slide" id="s3">
          <div class="eyebrow">The Market</div>
          <h2>Large, <span class="accent">underserved,</span><br />and no good options exist.</h2>
          <div class="hdiv"></div>
          <div class="g3" style="margin-top:8px;">
            <div class="card">
              <div class="stat-num">1,300+</div><div class="stat-lbl">
                Critical Access Hospitals<br />across the United States
              </div>
            </div>
            <div class="card">
              <div class="stat-num">80+</div><div class="stat-lbl">
                CAHs in Texas alone —<br />our initial beachhead
              </div>
            </div>
            <div class="card">
              <div class="stat-num" style="color:#fff; opacity:0.2; font-size:40px;">NULL</div><div
                class="stat-lbl"
                style="margin-top:12px;"
              >
                Scheduling tools built <em>for</em> CAHs —<br />not adapted from large health systems
              </div>
            </div>
          </div>
          <p class="sub" style="margin-top:22px; font-size:14px;">
            Enterprise tools (QGenda, UKG) require IT teams CAHs don't have. Generic apps (Aladtec, ShiftWizard) weren't
            designed for CAH compliance rules.<br /><strong style="color:var(--text);"
              >Nobody is solving this the right way.</strong
            >
          </p>
        </section>

        <!-- S4: Solution -->
        <section class="slide" id="s4">
          <div class="eyebrow">Our Solution</div>
          <h2>We schedule <span class="accent">your nurses.</span><br />You approve. Done.</h2>
          <div class="hdiv"></div>
          <div class="g2" style="margin-top:8px; align-items:start;">
            <ul class="clist">
              <li>
                <span class="ck">✓</span>AI-generated schedules built around your unit's rules — charge ratios, skill
                mix, overtime limits
              </li>
              <li>
                <span class="ck">✓</span>Three draft options every cycle: balanced coverage, fairness-optimized, and
                cost-optimized
              </li>
              <li>
                <span class="ck">✓</span>Real-time callout management — AI ranks top 3 replacements with reasoning,
                one-click approval
              </li>
              <li><span class="ck">✓</span>Schedules delivered as PDF and Excel. Nurses never touch the software.</li>
            </ul>
            <div class="card" style="background:rgba(0,180,255,0.05); border-color:rgba(0,180,255,0.3);">
              <div class="stat-lbl" style="margin-bottom:12px;">The core insight</div>
              <p style="font-size:18px; line-height:1.65; color:var(--text);">
                "CAH administrators don't have time to learn new software. They need the <span class="accent"
                  >schedule done</span
                > — and they need it right."
              </p>
              <div class="hdiv"></div>
              <p style="font-size:13px; color:var(--muted);">
                This is why we are a <strong style="color:var(--text);">managed service</strong>, not another scheduling
                app.
              </p>
            </div>
          </div>
        </section>

        <!-- S5: How It Works -->
        <section class="slide" id="s5">
          <div class="eyebrow">How It Works</div>
          <h2>Live in <span class="accent">under 2 weeks.</span><br />Zero IT involvement.</h2>
          <div class="hdiv"></div>
          <div class="g4" style="margin-top:8px;">
            <div class="card">
              <div class="step-n">STEP 01</div><div class="step-t">Upload Roster</div><div class="step-d">
                Export your nurse list from HR or EHR into Excel. Upload it to SimpleScheduleAI.
              </div>
            </div>
            <div class="card">
              <div class="step-n">STEP 02</div><div class="step-t">Configure Rules</div><div class="step-d">
                We configure your shift structure, Texas overtime constraints, and facility-specific requirements.
              </div>
            </div>
            <div class="card">
              <div class="step-n">STEP 03</div><div class="step-t">Review Drafts</div><div class="step-d">
                AI generates 3 schedule options. You review, provide feedback, and approve.
              </div>
            </div>
            <div class="card">
              <div class="step-n">STEP 04</div><div class="step-t">Go Live</div><div class="step-d">
                Schedules published and distributed. Callout replacements handled automatically going forward.
              </div>
            </div>
          </div>
          <div style="margin-top:20px; display:flex; gap:10px; flex-wrap:wrap;">
            <div class="pill">No IT project</div>
            <div class="pill">No staff training</div>
            <div class="pill">Automated audit trail</div>
            <div class="pill">Texas overtime compliance</div>
            <div class="pill">CMS PBJ reporting ready</div>
          </div>
        </section>

        <!-- S6: Competitive -->
        <section class="slide" id="s6">
          <div class="eyebrow">Competitive Advantage</div>
          <h2>Managed service vs.<br /><span class="accent2">scheduling software.</span></h2>
          <div class="vs-wrap">
            <div class="vs-col left">
              <div class="vs-lbl">Legacy Software Tools</div>
              <div class="vs-row"><span class="vx">✗</span> Require IT setup and ongoing maintenance</div>
              <div class="vs-row"><span class="vx">✗</span> Staff must log in and learn the tool</div>
              <div class="vs-row"><span class="vx">✗</span> Built for large health systems, not CAHs</div>
              <div class="vs-row"><span class="vx">✗</span> Admin still builds the schedule manually</div>
              <div class="vs-row"><span class="vx">✗</span> No Texas-specific compliance rules</div>
            </div>
            <div class="vs-mid">VS</div>
            <div class="vs-col right">
              <div class="vs-lbl" style="color:var(--accent);">SimpleScheduleAI</div>
              <div class="vs-row"><span class="vck">✓</span> Zero IT — live in under 2 weeks</div>
              <div class="vs-row"><span class="vck">✓</span> Nurses never touch software</div>
              <div class="vs-row"><span class="vck">✓</span> Purpose-built for CAHs (≤25 beds)</div>
              <div class="vs-row"><span class="vck">✓</span> We do the scheduling — you approve</div>
              <div class="vs-row"><span class="vck">✓</span> Texas overtime + CMS PBJ built in</div>
            </div>
          </div>
        </section>

        <!-- S7: Differentiators -->
        <section class="slide" id="s7">
          <div class="eyebrow">Why SimpleScheduleAI</div>
          <h2>Built for the <span class="accent">one problem</span><br />CAHs actually have.</h2>
          <div class="hdiv" style="margin:14px 0;"></div>
          <div class="g2" style="gap:14px;">
            <div class="card">
              <div class="step-t" style="font-size:15px;">🧠 AI-Ranked Callout Replacement</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                When a nurse calls out, the system surfaces the top 3 replacements with reasoning for each. One-click
                approval. No phone chain.
              </p>
            </div>
            <div class="card">
              <div class="step-t" style="font-size:15px;">📋 Texas Compliance, Built In</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Overtime rules, CMS PBJ staffing data, and audit trail logging enforced automatically — not something
                the admin tracks manually.
              </p>
            </div>
            <div class="card">
              <div class="step-t" style="font-size:15px;">⚖️ Three Schedule Philosophies</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Every cycle delivers balanced coverage, fairness-optimized, and cost-optimized drafts. Administrators
                choose — AI executes.
              </p>
            </div>
            <div class="card">
              <div class="step-t" style="font-size:15px;">🚀 No Adoption Risk</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Schedules arrive as Excel and PDF. Staff receive schedules exactly as before. Zero change management
                required.
              </p>
            </div>
          </div>
        </section>

        <!-- S8: Traction -->
        <section class="slide" id="s8">
          <div class="eyebrow">Traction &amp; Business Model</div>
