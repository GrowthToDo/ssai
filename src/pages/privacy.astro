---
import Layout from '~/layouts/PageLayout.astro';
import DarkHero from '~/components/widgets/DarkHero.astro';

const metadata = {
  title: 'Privacy Policy | SimpleScheduleAI',
  description: 'How SimpleScheduleAI collects, uses, and protects the information you share with us.',
};

const effectiveDate = "March 5, 2026";
const contactEmail = "support@simplescheduleai.com";
---

<Layout metadata={metadata}>
  <!-- Dark Hero -->
  <DarkHero
    badge="Legal"
    title="Privacy Policy"
    subtitle={metadata.description}
  />

  <!-- Content -->
  <section class="bg-page">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <p class="text-sm text-muted mb-10">Effective date: {effectiveDate}</p>

      <div class="mx-auto max-w-3xl space-y-10 text-default">

        <div>
          <h2 class="text-xl font-semibold">Overview</h2>
          <p class="mt-3 leading-relaxed">
            SimpleScheduleAI ("we," "us," or "our") operates SimpleScheduleAI.com and provides an assisted nurse scheduling service for Critical Access Hospitals. This Privacy Policy describes what information we collect, why we collect it, and how we use it. We keep this simple because we are a small team and we handle your information carefully.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">What we collect</h2>
          <p class="mt-3 leading-relaxed">
            We collect information you give us directly when you:
          </p>
          <ul class="mt-4 space-y-2">
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>Submit a contact form or pilot application (name, title, hospital name, email address)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>Use the scheduling cost calculator and choose to share your results (name, title, hospital name, email address, and the input values you entered)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>Email us directly</span>
            </li>
          </ul>
          <p class="mt-4 leading-relaxed">
            We may also collect standard technical data automatically when you visit our site, such as browser type, pages visited, and approximate location. This data is used only in aggregate to understand how visitors use the site.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">What we do not collect</h2>
          <p class="mt-3 leading-relaxed">
            We do not collect, process, or store any patient health information, medical records, or data covered by HIPAA. Our service is limited to nurse scheduling workflows. We do not act as a HIPAA Business Associate in the use of this website.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">How we use your information</h2>
          <ul class="mt-3 space-y-2">
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>To respond to your inquiry or follow up on a pilot application</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>To assess whether our service is a good fit for your hospital</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>To send relevant updates about the pilot or our service (you can opt out at any time)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
              <span>To improve how we explain and present our service</span>
            </li>
          </ul>
          <p class="mt-4 leading-relaxed">
            We do not sell your information. We do not rent it. We do not share it with advertisers.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">Third-party services</h2>
          <p class="mt-3 leading-relaxed">
            Form submissions from this site are transmitted to Google Sheets via Google Apps Script, which we use as a lightweight internal tracking tool. Google's privacy practices apply to any data processed through their infrastructure. You can review Google's privacy policy at google.com/privacy.
          </p>
          <p class="mt-3 leading-relaxed">
            Our site may also use third-party analytics tools to understand aggregate traffic patterns. These tools do not receive personally identifiable information from us.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">Data retention</h2>
          <p class="mt-3 leading-relaxed">
            We retain contact information for as long as it is relevant to an active conversation or pilot engagement. If you ask us to delete your information, we will do so within a reasonable time unless we are required to retain it for legal purposes.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">Your rights</h2>
          <p class="mt-3 leading-relaxed">
            You can request access to, correction of, or deletion of your personal information at any time by emailing us. We will respond promptly.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">Security</h2>
          <p class="mt-3 leading-relaxed">
            We take reasonable precautions to protect information you share with us. However, no data transmission over the internet is fully guaranteed to be secure. Do not send sensitive clinical or patient data through this website.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold">Changes to this policy</h2>
          <p class="mt-3 leading-relaxed">
            If we make material changes to this Privacy Policy, we will update the effective date at the top of this page. We encourage you to review this page periodically.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Dark contact band -->
  <section class="bg-slate-950 dark:bg-black">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto max-w-3xl">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">Contact</p>
        <h2 class="text-2xl font-bold text-white">Questions about this policy?</h2>
        <p class="mt-4 text-gray-400">
          If you have any questions about this Privacy Policy or how we handle your information, reach out directly.
        </p>
        <p class="mt-6 text-lg font-medium text-blue-400">
          <a href={`mailto:${contactEmail}`} class="hover:text-blue-300">{contactEmail}</a>
        </p>
        <p class="mt-2 text-sm text-gray-500">SimpleScheduleAI, Remote, US</p>
      </div>
    </div>
  </section>
</Layout>
