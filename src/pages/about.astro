---
import Layout from '~/layouts/PageLayout.astro';
import DarkHero from '~/components/widgets/DarkHero.astro';

const metadata = {
  title: 'About SimpleScheduleAI',
  description:
    'Assisted nurse scheduling for Critical Access Hospitals in Texas. We reduce scheduling load while your team keeps tools, control, and final approval.',
};

const stats = [
  { label: 'Built for', value: 'Critical Access Hospitals in Texas' },
  { label: 'Works with', value: 'Excel and your current format' },
  { label: 'Designed for', value: 'Nurse managers and leadership' },
  { label: 'Approach', value: 'Assisted, not replacement' },
];

const principles = [
  {
    title: 'You keep control',
    description:
      'Your team owns the rules, the exceptions, and the final approval. We support the work, you decide what goes live.',
  },
  {
    title: 'Fits your current workflow',
    description:
      'No new software rollout. No training burden. We work with the format you already use, including Excel.',
  },
  {
    title: 'Clear handoffs',
    description:
      'You get a review ready schedule, notes on conflicts and assumptions, and a simple validation summary for quick sign off.',
  },
];

const whatWeDo = [
  'Build draft schedules based on your inputs and constraints',
  'Validate coverage, gaps, conflicts, and common failure points',
  'Return a clean, review ready version for your approval',
];

const whatWeDoNotDo = [
  'We do not publish schedules without your approval',
  'We do not change your policies or override your leadership',
  'We do not replace your staff or act as your HR system',
];

const ctaLink = 'https://cal.com/gautham-8bdvdx/30min';
---

<Layout metadata={metadata}>
  <!-- Dark Hero -->
  <DarkHero
    badge="About Us"
    title="Built for hospitals where the schedule never stops"
    subtitle={metadata.description}
    actions={[
      { text: 'See how it works', href: '/how-it-works', variant: 'primary' },
      { text: 'Book a call', href: ctaLink, variant: 'secondary' },
    ]}
  />

  <!-- Stats -->
  <section class="bg-page">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-6">
              <dt class="text-xs font-semibold uppercase tracking-widest text-primary">{stat.label}</dt>
              <dd class="mt-3 text-lg font-semibold">{stat.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Principles -->
  <section class="bg-gray-50 dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">How we operate</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">Our operating principles</h2>
        <p class="mt-4 text-lg text-muted">This is a workflow support service, not a software rollout.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {
          principles.map((p) => (
            <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 p-7 shadow-sm">
              <h3 class="text-lg font-semibold">{p.title}</h3>
              <p class="mt-3 text-default">{p.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What we do / do not do -->
  <section class="bg-page">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Scope of service</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">Clear boundaries, by design</h2>
      </div>
      <div class="mx-auto max-w-6xl grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-7">
          <h3 class="text-xl font-semibold">What we do</h3>
          <ul class="mt-4 space-y-3">
            {
              whatWeDo.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary" />
                  <span class="text-default">{item}</span>
                </li>
              ))
            }
          </ul>
          <p class="mt-5 text-sm text-muted">You review and approve. Nothing is final until your team signs off.</p>
        </div>

        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-7">
          <h3 class="text-xl font-semibold">What we do not do</h3>
          <ul class="mt-4 space-y-3">
            {
              whatWeDoNotDo.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-gray-400" />
                  <span class="text-default">{item}</span>
                </li>
              ))
            }
          </ul>
          <p class="mt-5 text-sm text-muted">This clarity is intentional. It keeps expectations clean and risk low.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dark CTA -->
  <section class="bg-slate-950 dark:bg-black">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">Low risk. No obligation.</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Want to sanity check fit before anything else?
        </h2>
        <p class="mt-5 text-lg text-gray-400">
          If scheduling is draining time and attention, the pilot is a practical way to see if assisted scheduling works for your unit.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href="/pilot" class="btn btn-primary"> View the pilot </a>
          <a href={ctaLink} class="btn text-white border-white/30 hover:bg-white/10 hover:border-white">
            Book a call
          </a>
        </div>
        <p class="mt-6 text-sm text-gray-500">Simple process. Clear handoffs. Your final approval.</p>
      </div>
    </div>
  </section>
</Layout>
