// Style selection preview — temp file, delete after picking a style
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Slides — Pick a Style</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0a0a0a;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      color: #fff;
      padding: 48px 40px;
    }
    .page-title {
      font-size: 15px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      color: #666; margin-bottom: 8px;
    }
    .page-sub { font-size: 28px; font-weight: 700; color: #fff; margin-bottom: 48px; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }

    /* ── Option labels ── */
    .option { display: flex; flex-direction: column; gap: 16px; }
    .option-label {
      font-size: 13px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #555;
    }
    .option-name { font-size: 22px; font-weight: 800; color: #fff; }
    .option-desc { font-size: 14px; color: #666; line-height: 1.6; margin-top: 4px; }

    /* ── Slide frame wrapper ── */
    .frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 12px;
      overflow: hidden;
      border: 2px solid #222;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.2s;
    }
    .frame:hover { border-color: #555; transform: translateY(-2px); }

    /* ─────────────────────────────────────────────
       STYLE A: "Dark Command"
       Near-black, electric blue, sharp grid lines,
       high-density data feel. Bloomberg meets startup.
    ───────────────────────────────────────────── */
    .a {
      background: #05050f;
      padding: 9% 10%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .a::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,200,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,200,255,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    .a::after {
      content: '';
      position: absolute; right: -60px; top: 50%; transform: translateY(-50%);
      width: 280px; height: 280px; border-radius: 50%;
      background: radial-gradient(circle, rgba(0,180,255,0.12) 0%, transparent 70%);
      border: 1px solid rgba(0,180,255,0.2);
    }
    .a-eyebrow {
      font-size: 7px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
      color: #00b4ff; margin-bottom: 14px;
      display: flex; align-items: center; gap: 8px;
    }
    .a-eyebrow::before {
      content: ''; display: block; width: 20px; height: 1px; background: #00b4ff;
    }
    .a h1 {
      font-size: 28px; font-weight: 900; line-height: 1.05; letter-spacing: -0.03em;
      color: #fff; margin-bottom: 12px; position: relative; z-index: 1;
    }
    .a h1 span { color: #00b4ff; }
    .a-sub { font-size: 9px; color: rgba(255,255,255,0.45); line-height: 1.7; position: relative; z-index: 1; }
    .a-pills {
      display: flex; gap: 8px; margin-top: 16px; position: relative; z-index: 1;
    }
    .a-pill {
      font-size: 7px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 3px 8px; border: 1px solid rgba(0,180,255,0.4); border-radius: 2px;
      color: #00b4ff;
    }

    /* ─────────────────────────────────────────────
       STYLE B: "Warm Authority"
       Deep warm navy, gold/amber accents, serif-weight
       headlines, textured feel. Old-money meets healthcare.
    ───────────────────────────────────────────── */
    .b {
      background: linear-gradient(135deg, #0f0c1e 0%, #1a1230 100%);
      padding: 9% 10%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .b::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 85% 15%, rgba(212,175,55,0.10) 0%, transparent 50%),
        radial-gradient(ellipse at 15% 85%, rgba(130,80,200,0.10) 0%, transparent 50%);
    }
    .b-bar {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 4px;
      background: linear-gradient(180deg, #d4af37, #8040c0);
    }
    .b-eyebrow {
      font-size: 7px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
      color: #d4af37; margin-bottom: 14px;
    }
    .b h1 {
      font-size: 27px; font-weight: 800; line-height: 1.1; letter-spacing: -0.02em;
      color: #f5f0e8; margin-bottom: 12px; position: relative; z-index: 1;
    }
    .b h1 span { color: #d4af37; }
    .b-sub { font-size: 9px; color: rgba(245,240,232,0.5); line-height: 1.7; position: relative; z-index: 1; }
    .b-divider {
      width: 32px; height: 2px; margin: 14px 0;
      background: linear-gradient(90deg, #d4af37, #8040c0);
    }
    .b-founders {
      font-size: 7px; color: rgba(245,240,232,0.35); font-weight: 500; letter-spacing: 0.05em;
    }
    .b-founders strong { color: rgba(245,240,232,0.7); }

    /* ─────────────────────────────────────────────
       STYLE C: "Bold Minimal"
       Pure black, white headlines at massive scale,
       single punch-green accent, brutalist whitespace.
       Y Combinator / a16z energy.
    ───────────────────────────────────────────── */
    .c {
      background: #000;
      padding: 9% 10%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .c-accent-line {
      position: absolute; top: 0; left: 0; right: 0;
      height: 3px;
      background: #00ff88;
    }
    .c-eyebrow {
      font-size: 7px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
      color: #00ff88; margin-bottom: 18px;
    }
    .c h1 {
      font-size: 36px; font-weight: 900; line-height: 0.95; letter-spacing: -0.04em;
      color: #fff; text-transform: uppercase; margin-bottom: 16px;
    }
    .c h1 em { font-style: normal; color: #00ff88; }
    .c-sub {
      font-size: 9px; color: rgba(255,255,255,0.4); line-height: 1.7;
      border-left: 2px solid #333; padding-left: 10px;
      max-width: 70%;
    }
    .c-stat {
      position: absolute; right: 10%; bottom: 12%;
      text-align: right;
    }
    .c-stat-num {
      font-size: 52px; font-weight: 900; letter-spacing: -0.05em;
      color: #fff; line-height: 1; opacity: 0.08;
    }
  </style>
</head>
<body>

<div class="page-title">SimpleScheduleAI — Pitch Deck</div>
<div class="page-sub">Pick a visual style. Click to see a full sample slide.</div>

<div class="grid">

  <!-- ── OPTION A ── -->
  <div class="option">
    <div>
      <div class="option-label">Option A</div>
      <div class="option-name">Dark Command</div>
      <div class="option-desc">Near-black with electric cyan, subtle grid texture, data-dense feel. Signals: "We built real technology."</div>
    </div>
    <div class="frame" onclick="open('/slides-preview-a', '_blank')">
      <div class="a">
        <div class="a-eyebrow">SimpleScheduleAI</div>
        <h1>Nurse Scheduling<br>for <span>Critical Access</span><br>Hospitals — Solved.</h1>
        <div class="a-sub">An AI-powered managed service that eliminates manual<br>scheduling so administrators can run their hospital.</div>
        <div class="a-pills">
          <div class="a-pill">Texas · 2024</div>
          <div class="a-pill">Free 60-Day Pilot</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── OPTION B ── -->
  <div class="option">
    <div>
      <div class="option-label">Option B</div>
      <div class="option-name">Warm Authority</div>
      <div class="option-desc">Deep navy with gold accents, lateral accent bar, textured gradient. Signals: "We understand healthcare's weight."</div>
    </div>
    <div class="frame" onclick="open('/slides-preview-b', '_blank')">
      <div class="b">
        <div class="b-bar"></div>
        <div class="b-eyebrow">SimpleScheduleAI · Pitch Deck · 2024</div>
        <h1>Nurse Scheduling<br>for <span>Critical Access</span><br>Hospitals — Solved.</h1>
        <div class="b-divider"></div>
        <div class="b-sub">An AI-powered managed service that eliminates<br>manual scheduling burden for CAH administrators.</div>
        <div class="b-founders" style="margin-top: 18px;"><strong>Pradeep Pandey</strong> · Founder · Texas</div>
      </div>
    </div>
  </div>

  <!-- ── OPTION C ── -->
  <div class="option">
    <div>
      <div class="option-label">Option C</div>
      <div class="option-name">Bold Minimal</div>
      <div class="option-desc">Pure black, oversized uppercase type, single electric-green accent. Signals: "We know exactly what we're doing."</div>
    </div>
    <div class="frame" onclick="open('/slides-preview-c', '_blank')">
      <div class="c">
        <div class="c-accent-line"></div>
        <div class="c-eyebrow">SimpleScheduleAI</div>
        <h1>Nurse<br><em>Scheduling</em><br>Solved.</h1>
        <div class="c-sub">AI-powered managed service for Critical Access Hospitals.<br>We schedule your nurses. You approve. Done.</div>
        <div class="c-stat">
          <div class="c-stat-num">CAH</div>
        </div>
      </div>
    </div>
  </div>

</div>

<div style="margin-top: 48px; font-size: 14px; color: #444; text-align: center;">
  Tell Claude which option you prefer (A, B, or C) and the full deck will be built in that style.
</div>

</body>
</html>
