---
// Style C: Bold Minimal — full pitch deck
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SimpleScheduleAI — Pitch Deck</title>
    <meta name="robots" content="noindex" />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #000000;
        --surface: #0d0d0d;
        --border: #1e1e1e;
        --accent: #00ff88;
        --accent2: #ff3cac;
        --text: #ffffff;
        --muted: rgba(255, 255, 255, 0.38);
        --muted2: rgba(255, 255, 255, 0.15);
      }

      html,
      body {
        width: 100%;
        height: 100%;
        background: #000;
        overflow: hidden;
        user-select: none;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        color: var(--text);
      }

      #scaler {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      #deck {
        position: relative;
        width: 1280px;
        height: 720px;
        transform-origin: center center;
        overflow: hidden;
      }

      .slide {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        padding: 56px 72px;
        background: var(--bg);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
      }
      .slide.active {
        opacity: 1;
        pointer-events: auto;
      }

      /* top accent bar */
      .slide::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--accent);
      }

      /* ── typography ── */
      .eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 20px;
      }

      h1 {
        font-size: 80px;
        font-weight: 900;
        line-height: 0.92;
        letter-spacing: -0.04em;
        text-transform: uppercase;
      }
      h2 {
        font-size: 56px;
        font-weight: 900;
        line-height: 0.95;
        letter-spacing: -0.04em;
        text-transform: uppercase;
      }
      .accent {
        color: var(--accent);
      }
      .accent2 {
        color: var(--accent2);
      }

      .sub {
        font-size: 15px;
        color: var(--muted);
        line-height: 1.75;
        border-left: 2px solid #222;
        padding-left: 16px;
        margin-top: 22px;
      }

      /* rule */
      .rule {
        height: 1px;
        background: #1a1a1a;
        margin: 20px 0;
      }

      /* card */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0;
        padding: 20px 24px;
      }

      /* stat */
      .stat-num {
        font-size: 48px;
        font-weight: 900;
        letter-spacing: -0.04em;
        color: var(--accent);
        line-height: 1;
      }
      .stat-lbl {
        font-size: 12px;
        color: var(--muted);
        margin-top: 6px;
        line-height: 1.5;
      }

      /* grids */
      .g2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }
      .g3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }
      .g4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }

      /* check list */
      .clist {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .clist li {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        font-size: 15px;
        color: var(--text);
        line-height: 1.5;
      }
      .ck {
        flex-shrink: 0;
        font-size: 13px;
        color: var(--accent);
        margin-top: 1px;
        font-weight: 900;
      }

      /* step */
      .step-n {
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.2em;
        color: var(--accent);
        margin-bottom: 8px;
      }
      .step-t {
        font-size: 15px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        margin-bottom: 8px;
      }
      .step-d {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.55;
      }

      /* pill */
      .pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        border-radius: 0;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: transparent;
        border: 1px solid #2a2a2a;
        color: var(--muted);
      }

      /* VS */
      .vs-wrap {
        display: grid;
        grid-template-columns: 1fr 40px 1fr;
        margin-top: 20px;
      }
      .vs-col {
        padding: 20px 24px;
        border: 1px solid var(--border);
      }
      .vs-col.left {
        border-right: none;
      }
      .vs-col.right {
        border-left: none;
        background: #0a0a0a;
        border-top-color: var(--accent);
      }
      .vs-mid {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 0.15em;
        color: #2a2a2a;
        background: #000;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .vs-lbl {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px;
      }
      .vs-row {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
        margin-bottom: 10px;
      }
      .vx {
        color: #444;
        font-size: 14px;
        font-weight: 900;
      }
      .vck {
        color: var(--accent);
        font-size: 14px;
        font-weight: 900;
      }

      /* nav */
      #nav {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 12px;
        background: #0d0d0d;
        border: 1px solid #1e1e1e;
        border-radius: 0;
        padding: 8px 16px;
        z-index: 100;
      }
      #nav button {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--muted);
        font-size: 16px;
        padding: 3px 6px;
      }
      #nav button:hover {
        color: var(--text);
      }
      #counter {
        font-size: 11px;
        color: var(--muted);
        min-width: 44px;
        text-align: center;
        letter-spacing: 0.1em;
      }
      .dots {
        display: flex;
        gap: 6px;
        align-items: center;
      }
      .dn {
        width: 5px;
        height: 5px;
        background: #2a2a2a;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: all 0.2s;
      }
      .dn.active {
        background: var(--accent);
        width: 20px;
      }

      /* s1 */
      #s1 {
        flex-direction: row;
        align-items: stretch;
        padding: 0;
      }
      #s1 .s1-left {
        flex: 1;
        padding: 56px 64px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-right: 1px solid #111;
      }
      #s1 .s1-right {
        width: 380px;
        padding: 56px 48px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: #050505;
      }
      #s1 h1 {
        font-size: 72px;
      }
      #s1 .s1-stat {
      }
      #s1 .s1-big {
        font-size: 96px;
        font-weight: 900;
        letter-spacing: -0.06em;
        line-height: 1;
        color: var(--accent);
      }
      #s1 .s1-big-lbl {
        font-size: 12px;
        color: var(--muted);
        margin-top: 8px;
        line-height: 1.6;
      }
      #s1 .s1-founder {
        font-size: 12px;
        color: var(--muted);
      }
      #s1 .s1-founder strong {
        color: var(--text);
      }
      #s1 .s1-pills {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      /* pain cards */
      #s2 .pain-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        margin-top: 24px;
        background: #111;
      }
      #s2 .pain-card {
        background: var(--bg);
        padding: 24px;
      }
      #s2 .pain-num {
        font-size: 40px;
        font-weight: 900;
        letter-spacing: -0.04em;
        color: var(--accent);
        margin-bottom: 10px;
      }
      #s2 .pain-t {
        font-size: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
      }
      #s2 .pain-d {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
      }

      /* s9 */
      #s9 {
        flex-direction: row;
        align-items: stretch;
        padding: 0;
      }
      #s9 .s9-left {
        flex: 1;
        padding: 56px 64px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-right: 1px solid #111;
      }
      #s9 .s9-right {
        width: 340px;
        background: var(--accent);
        padding: 56px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 20px;
      }
      #s9 .s9-right * {
        color: #000 !important;
      }
      #s9 .s9-rh {
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #000;
        margin-bottom: 12px;
      }
      #s9 .s9-rl {
        font-size: 20px;
        font-weight: 900;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }
      #s9 .s9-url {
        font-size: 12px;
        font-weight: 700;
        opacity: 0.6;
        margin-top: 24px;
      }
    </style>
  </head>
  <body>
    <div id="scaler">
      <div id="deck">
        <!-- S1: Title -->
        <section class="slide active" id="s1">
          <div class="s1-left">
            <div class="eyebrow">SimpleScheduleAI</div>
            <h1>Nurse<br /><span class="accent">Scheduling</span><br />Solved.</h1>
            <div class="sub">
              AI-powered managed service for Critical Access Hospitals.<br />We schedule your nurses. You approve. Done.
            </div>
          </div>
          <div class="s1-right">
            <div class="s1-stat">
              <div class="s1-big">≤25</div>
              <div class="s1-big-lbl">beds. Every CAH is underserved<br />by every tool on the market.</div>
            </div>
            <div class="s1-pills">
              <div class="s1-founder"><strong>Pradeep Pandey</strong> · Founder</div>
              <div style="height:1px; background:#111; margin:4px 0;"></div>
              <div class="pill" style="border-color: #2a2a2a;">Texas · 2024</div>
              <div class="pill" style="border-color: rgba(0,255,136,0.4); color: var(--accent);">
                Free 60-Day Pilot Open
              </div>
            </div>
          </div>
        </section>

        <!-- S2: Problem -->
        <section class="slide" id="s2">
          <div class="eyebrow">The Problem</div>
          <h2>CAH Managers<br /><span class="accent">Buried</span> in Scheduling.</h2>
          <div class="pain-grid">
            <div class="pain-card">
              <div class="pain-num">8–12</div>
              <div class="pain-t">Hours / Week — Gone</div>
              <div class="pain-d">
                Nurse managers spend a full workday each week juggling spreadsheets and manually enforcing shift rules.
              </div>
            </div>
            <div class="pain-card">
              <div class="pain-num" style="color:var(--accent2);">Rule</div>
              <div class="pain-t">Violations</div>
              <div class="pain-d">
                Texas overtime rules, CMS PBJ reporting, charge nurse ratios — manual scheduling misses constraints that
                trigger compliance risk.
              </div>
            </div>
            <div class="pain-card">
              <div class="pain-num">Chaos</div>
              <div class="pain-t">Every Callout</div>
              <div class="pain-d">
                A single unexpected callout cascades into hours of calls, texts, and manual rescheduling — every time,
                every shift.
              </div>
            </div>
          </div>
        </section>

        <!-- S3: Market -->
        <section class="slide" id="s3">
          <div class="eyebrow">The Market</div>
          <h2>Large.<br /><span class="accent">Underserved.</span><br />No Good Options.</h2>
          <div class="rule" style="margin:20px 0;"></div>
          <div class="g3">
            <div class="card">
              <div class="stat-num">1,300+</div><div class="stat-lbl">
                Critical Access Hospitals<br />across the United States
              </div>
            </div>
            <div class="card">
              <div class="stat-num">80+</div><div class="stat-lbl">
                CAHs in Texas alone —<br />our initial beachhead
              </div>
            </div>
            <div class="card">
              <div class="stat-num" style="color:#2a2a2a;">0</div><div class="stat-lbl" style="margin-top:8px;">
                Tools built specifically for CAHs — not adapted from enterprise health systems
              </div>
            </div>
          </div>
          <p class="sub" style="margin-top:20px; font-size:13px;">
            Enterprise tools (QGenda, UKG) require IT teams CAHs don't have. Generic apps (Aladtec, ShiftWizard) lack
            CAH compliance rules. <strong style="color:var(--text);">Nobody is solving this correctly.</strong>
          </p>
        </section>

        <!-- S4: Solution -->
        <section class="slide" id="s4">
          <div class="eyebrow">Our Solution</div>
          <h2>We Schedule<br /><span class="accent">Your Nurses.</span><br />You Approve.</h2>
          <div class="rule" style="margin:18px 0;"></div>
          <div class="g2" style="align-items:start;">
            <ul class="clist">
              <li>
                <span class="ck">→</span>AI-generated schedules built around your unit's rules — charge ratios, skill
                mix, overtime limits
              </li>
              <li>
                <span class="ck">→</span>Three draft options every cycle: balanced coverage, fairness-optimized, and
                cost-optimized
              </li>
              <li>
                <span class="ck">→</span>Real-time callout management — AI ranks top 3 replacements with reasoning,
                one-click approval
              </li>
              <li><span class="ck">→</span>Schedules delivered as PDF and Excel. Nurses never touch the software.</li>
            </ul>
            <div class="card" style="border-top: 3px solid var(--accent);">
              <div class="stat-lbl" style="margin-bottom:10px; text-transform:uppercase; letter-spacing:0.12em;">
                The Core Insight
              </div>
              <p style="font-size:17px; line-height:1.65;">
                "CAH administrators don't have time to learn new software. They need the <span class="accent"
                  >schedule done</span
                > — and done right."
              </p>
              <div class="rule" style="margin:14px 0;"></div>
              <p style="font-size:13px; color:var(--muted);">
                This is why we are a <strong style="color:var(--text);">managed service</strong>, not another scheduling
                app.
              </p>
            </div>
          </div>
        </section>

        <!-- S5: How -->
        <section class="slide" id="s5">
          <div class="eyebrow">How It Works</div>
          <h2>Live in<br /><span class="accent">2 Weeks.</span><br />Zero IT.</h2>
          <div class="rule" style="margin:18px 0;"></div>
          <div class="g4">
            <div class="card" style="border-top:2px solid var(--accent);">
              <div class="step-n">01</div><div class="step-t">Upload Roster</div><div class="step-d">
                Export your nurse list from HR or EHR into Excel. Upload it to SimpleScheduleAI.
              </div>
            </div>
            <div class="card" style="border-top:2px solid #222;">
              <div class="step-n">02</div><div class="step-t">Configure Rules</div><div class="step-d">
                We configure your shift structure, Texas overtime constraints, and facility-specific requirements.
              </div>
            </div>
            <div class="card" style="border-top:2px solid #222;">
              <div class="step-n">03</div><div class="step-t">Review Drafts</div><div class="step-d">
                AI generates 3 schedule options. You review, provide feedback, and approve.
              </div>
            </div>
            <div class="card" style="border-top:2px solid #222;">
              <div class="step-n">04</div><div class="step-t">Go Live</div><div class="step-d">
                Schedules published. Callout replacements handled automatically going forward.
              </div>
            </div>
          </div>
          <div style="margin-top:18px; display:flex; gap:8px; flex-wrap:wrap;">
            <div class="pill">No IT project</div>
            <div class="pill">No staff training</div>
            <div class="pill">Audit trail</div>
            <div class="pill">TX overtime</div>
            <div class="pill">CMS PBJ ready</div>
          </div>
        </section>

        <!-- S6: Competitive -->
        <section class="slide" id="s6">
          <div class="eyebrow">Competitive Advantage</div>
          <h2>Managed Service<br />vs. <span class="accent2">Software.</span></h2>
          <div class="vs-wrap">
            <div class="vs-col left">
              <div class="vs-lbl">Legacy Software Tools</div>
              <div class="vs-row"><span class="vx">✗</span> Require IT setup and ongoing maintenance</div>
              <div class="vs-row"><span class="vx">✗</span> Staff must log in and learn the tool</div>
              <div class="vs-row"><span class="vx">✗</span> Built for large health systems, not CAHs</div>
              <div class="vs-row"><span class="vx">✗</span> Admin still builds the schedule manually</div>
              <div class="vs-row"><span class="vx">✗</span> No Texas-specific compliance rules</div>
            </div>
            <div class="vs-mid">VS</div>
            <div class="vs-col right">
              <div class="vs-lbl" style="color:var(--accent);">SimpleScheduleAI</div>
              <div class="vs-row"><span class="vck">✓</span> Zero IT — live in under 2 weeks</div>
              <div class="vs-row"><span class="vck">✓</span> Nurses never touch software</div>
              <div class="vs-row"><span class="vck">✓</span> Purpose-built for CAHs (≤25 beds)</div>
              <div class="vs-row"><span class="vck">✓</span> We do the scheduling — you approve</div>
              <div class="vs-row"><span class="vck">✓</span> Texas overtime + CMS PBJ built in</div>
            </div>
          </div>
        </section>

        <!-- S7: Differentiators -->
        <section class="slide" id="s7">
          <div class="eyebrow">Why SimpleScheduleAI</div>
          <h2>One Problem.<br /><span class="accent">Built Right.</span></h2>
          <div class="rule" style="margin:16px 0;"></div>
          <div class="g2" style="gap:12px;">
            <div class="card" style="border-top:2px solid var(--accent);">
              <div class="step-t">🧠 AI-Ranked Callout Replacement</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                When a nurse calls out, the system surfaces the top 3 replacements with reasoning for each. One-click
                approval. No phone chain.
              </p>
            </div>
            <div class="card" style="border-top:2px solid #1e1e1e;">
              <div class="step-t">📋 Texas Compliance, Built In</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Overtime rules, CMS PBJ staffing data, and audit trail logging enforced automatically — not something
                the admin tracks manually.
              </p>
            </div>
            <div class="card" style="border-top:2px solid #1e1e1e;">
              <div class="step-t">⚖️ Three Schedule Philosophies</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Every cycle delivers balanced coverage, fairness-optimized, and cost-optimized drafts. Administrators
                choose — AI executes.
              </p>
            </div>
            <div class="card" style="border-top:2px solid #1e1e1e;">
              <div class="step-t">🚀 No Adoption Risk</div><p
                style="font-size:13px; color:var(--muted); margin-top:8px; line-height:1.6;"
              >
                Schedules arrive as Excel and PDF. Staff receive schedules exactly as before. Zero change management
                required.
              </p>
            </div>
          </div>
        </section>

        <!-- S8: Traction -->
        <section class="slide" id="s8">
          <div class="eyebrow">Traction &amp; Business Model</div>
          <h2>Starting<br />with <span class="accent">Texas.</span></h2>
          <div class="rule" style="margin:16px 0;"></div>
          <div class="g2" style="align-items:start;">
            <div style="display:flex; flex-direction:column; gap:12px;">
              <div class="card">
                <div class="vs-lbl" style="margin-bottom:10px;">Business Model</div>
                <ul class="clist" style="gap:8px;">
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >Recurring monthly managed service fee per facility</span
                    >
                  </li>
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >SaaS-like unit economics — one contract, recurring revenue</span
                    >
                  </li>
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >Expansion: multi-state CAH networks, rural health systems</span
                    >
                  </li>
                </ul>
              </div>
              <div class="card">
                <div class="vs-lbl" style="margin-bottom:10px;">Go-To-Market</div>
                <ul class="clist" style="gap:8px;">
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >Texas CAHs as beachhead — 80+ facilities, direct outreach</span
                    >
                  </li>
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >Free 60-day pilot removes procurement friction</span
                    >
                  </li>
                  <li>
                    <span class="ck">→</span><span style="font-size:13px;"
                      >Word-of-mouth through Texas Hospital Association network</span
                    >
                  </li>
                </ul>
              </div>
            </div>
            <div
              class="card"
              style="border-top:3px solid var(--accent); display:flex; flex-direction:column; gap:14px;"
            >
              <div>
                <div class="stat-num" style="font-size:44px;">60-Day</div><div
                  class="stat-lbl"
                  style="font-size:14px; margin-top:6px;"
                >
                  Free pilot — no contract, no IT project, no risk
                </div>
              </div>
              <div class="rule" style="margin:0;"></div>
