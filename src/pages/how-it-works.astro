---
import Layout from '~/layouts/PageLayout.astro';
import SchemaOrg from '~/components/common/SchemaOrg.astro';
import DarkHero from '~/components/widgets/DarkHero.astro';
import Steps from '~/components/widgets/Steps.astro';
import ComplianceRules from '~/components/widgets/ComplianceRules.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'How it Works',
  description:
    'A simple, collaborative workflow for assisted nurse scheduling at Critical Access Hospitals in Texas. Your rules, your final approval, fewer headaches.',
};

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'SimpleScheduleAI',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'Healthcare Scheduling Software',
  operatingSystem: 'Web',
  url: 'https://simplescheduleai.com',
  description:
    'AI-powered nurse scheduling software for critical access hospitals. Generates balanced, fair, and cost-optimized nurse schedules, handles callout replacements automatically, and tracks Texas overtime compliance.',
  audience: {
    '@type': 'Audience',
    audienceType: 'Nurse Managers, Directors of Nursing, CAH Administrators',
  },
  featureList: [
    'AI-generated nurse schedules',
    'Three draft options: balanced, fairness-optimized, cost-optimized',
    'Real-time callout replacement shortlist',
    'Excel roster upload',
    'Texas overtime compliance tracking',
    'Audit trail logging',
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Set Up Automated Nurse Scheduling for a Critical Access Hospital',
  description:
    'A step-by-step guide to implementing AI-assisted nurse scheduling at a 25-bed critical access hospital using SimpleScheduleAI.',
  totalTime: 'PT1W',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Upload your existing nurse roster',
      text: 'Export your current nurse roster from your HR or EHR system into Excel format and upload it to SimpleScheduleAI. The system accepts standard .xlsx files with columns for nurse name, role, certifications, and availability.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Configure shift rules and compliance parameters',
      text: "Set your hospital's shift structure (days, nights, weekends), Texas overtime rules, and any facility-specific constraints such as minimum rest periods between shifts.",
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Review the three AI-generated schedule drafts',
      text: 'SimpleScheduleAI generates three schedule options: balanced coverage, fairness-optimized (equitable shift distribution), and cost-optimized (minimizes overtime). The nurse manager reviews and selects or modifies.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Publish and distribute the approved schedule',
      text: 'Once approved, the schedule is published and distributed to nursing staff. The audit trail is automatically logged for compliance review.',
    },
  ],
};
---

<Layout metadata={metadata}>
  <SchemaOrg slot="head" schema={[softwareAppSchema, howToSchema]} />
  <!-- Dark Hero -->
  <DarkHero
    badge="Clear workflow. Predictable handoffs."
    title="How it Works"
    subtitle="Assisted scheduling that fits into your current process. You keep control and final approval. We reduce the scheduling workload."
    actions={[
      { text: 'View the Pilot', href: '/pilot', variant: 'primary' },
      { text: 'Book a call', href: 'https://cal.com/gautham-8bdvdx/30min', variant: 'secondary' },
    ]}
  />

  <!-- What you send / What you get -->
  <section class="bg-page">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Simple handoff</p>
          <h2 class="text-balance text-3xl font-bold tracking-tight sm:text-4xl">
            What you send us. What you get back.
          </h2>
          <p class="mt-5 text-lg text-muted">
            We work with the format you already use. Excel is fine. No new software for your staff.
          </p>

          <div class="mt-8 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-7">
            <h3 class="font-bold">What you send us</h3>
            <ul class="mt-4 space-y-3">
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
                <span class="text-muted">Staff roster via Excel (roles, competency levels, home units)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
                <span class="text-muted">PRN availability submissions and leave requests</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary"></span>
                <span class="text-muted">Unit rules: weekend requirements, escalation order, OT thresholds</span>
              </li>
            </ul>
            <p class="mt-4 text-sm text-muted">Export your current data, edit in Excel, re-import. Simple.</p>
          </div>
        </div>

        <div>
          <div class="rounded-2xl border-2 border-primary bg-blue-50 dark:bg-blue-950/30 p-7">
            <h3 class="font-bold">What you get back</h3>
            <ul class="mt-4 space-y-3">
              <li class="flex items-start gap-3">
                <Icon name="tabler:check" class="w-5 h-5 text-primary mt-1 shrink-0" />
                <span class="text-gray-700 dark:text-gray-300"
                  >Compliant, post-ready schedule (21 rules checked automatically)</span
                >
              </li>
              <li class="flex items-start gap-3">
                <Icon name="tabler:check" class="w-5 h-5 text-primary mt-1 shrink-0" />
                <span class="text-gray-700 dark:text-gray-300"
                  >Multiple schedule drafts showing different coverage, cost, and fairness trade-offs</span
                >
              </li>
              <li class="flex items-start gap-3">
                <Icon name="tabler:check" class="w-5 h-5 text-primary mt-1 shrink-0" />
                <span class="text-gray-700 dark:text-gray-300"
                  >Auto-recommended replacements when leave is approved</span
                >
              </li>
              <li class="flex items-start gap-3">
                <Icon name="tabler:check" class="w-5 h-5 text-primary mt-1 shrink-0" />
                <span class="text-gray-700 dark:text-gray-300">Full audit trail of every change for compliance</span>
              </li>
            </ul>
            <p class="mt-4 text-sm text-muted">Nothing is final until your team signs off.</p>
          </div>

          <div class="mt-6 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-slate-800 p-6">
            <p class="text-sm font-semibold">Delivered every Thursday, 3pm</p>
            <p class="mt-2 text-sm text-muted">
              PDF schedule, a manager summary with flagged items, and full data for your records. Ready for your review
              before posting.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-step workflow -->
  <Steps
    title="Four steps. No surprises."
    subtitle="A structured collaboration that respects your existing process."
    tagline="The process"
    items={[
      {
        title: 'Kickoff and rules',
        description: 'We document your rules, constraints, and what a good schedule looks like for your unit.',
        icon: 'tabler:number-1',
      },
      {
        title: 'Inputs and handoff',
        description: 'Your team shares availability and coverage requirements in the format you already use.',
        icon: 'tabler:number-2',
      },
      {
        title: 'Build and validate',
        description:
          'We build the schedule and check all 21 rules: coverage, safety requirements, fairness, and scheduling conflicts.',
        icon: 'tabler:number-3',
      },
      {
        title: 'Your review and approval',
        description: 'Your team reviews, adjusts if needed, and approves. You stay in full control.',
        icon: 'tabler:number-4',
      },
    ]}
  />

  <!-- 13 + 8 Rules Detail -->
  <ComplianceRules />

  <!-- FAQ -->
  <FAQs
    title="Questions about the process"
    tagline="Common questions"
    items={[
      {
        title: 'How do we get our data in?',
        description: 'Excel upload. Export your current data, edit, re-import anytime. No new software for your staff.',
      },
      {
        title: 'What happens when someone calls out?',
        description:
          'The system auto-finds the top 3 replacement candidates with reasons. You approve with one click. You do not have to call us, but we are reachable if something unusual comes up.',
      },
      {
        title: 'How is fairness tracked?',
        description:
          'Weekends (no more than 3 per 6-week period), holidays (tracked annually), overtime, and charge duty distribution. All automatic.',
      },
      {
        title: 'What about compliance and audits?',
        description:
          'Full audit trail of every change: who, what, when. Exportable anytime. Staffing committee packet ready in one click.',
      },
      {
        title: 'What if we already use a scheduling system?',
        description:
          'We do not replace your EMR. Most pilots come from teams using spreadsheets or a basic tool that does not enforce rules. We deliver the schedule so you do not have to build it.',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    title="Ready to test this in your hospital?"
    subtitle="See if assisted scheduling reduces the workload on your team. Free for 60 days. No obligation."
    tagline="3 spots open"
    actions={[
      { text: 'View the Pilot', href: '/pilot', variant: 'primary' },
      { text: 'Book a call', href: 'https://cal.com/gautham-8bdvdx/30min', variant: 'secondary' },
    ]}
  />
</Layout>
