---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';
import type { Widget } from '~/types';

type Props = Widget;

const {
  id,
  isDark = true,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const title = "21 rules validated on every schedule";
const subtitle = "Every draft is automatically checked before it reaches you. No rule can be quietly skipped.";

const complianceRules = [
  "Charge nurse on every shift",
  "Minimum RN-to-patient ratio met per shift",
  "Minimum 2 rest days per 7-day period per nurse",
  "Minimum rest between shifts: 11 hours standard, 12 hours after a night shift",
  "No double-booking: a nurse cannot be assigned to overlapping shifts",
  "No scheduling during approved PTO",
  "PRN staff within contracted availability",
  "Required certifications present per shift (BLS, ACLS)",
  "Float staff within licensed scope of practice",
  "OT threshold not exceeded without flag",
  "Minimum total staff count per shift",
  "Skill mix requirement satisfied per unit",
  "All schedule changes are documented with the approver detail",
];

const fairnessGoals = [
  "Weekend equity: no nurse should work more than 3 weekends in any 6-week period",
  "Holiday shifts distributed fairly across the team, tracked annually",
  "Charge duty distributed evenly across eligible staff",
  "Night shift burden shared across the team",
  "Staff shift preferences honored when possible",
  "Overtime spread evenly when OT is unavoidable",
  "Extra hours above FTE minimized per nurse",
  "Float pool assignments rotated fairly",
];
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl ${classes?.container ?? ''}`} bg={bg}>
  <div class="mx-auto max-w-3xl text-center mb-14">
    <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">Built-in compliance</p>
    <Headline title={title} subtitle={subtitle} classes={{ title: 'text-3xl sm:text-4xl text-white', subtitle: 'text-lg text-gray-400' }} />
  </div>

  <div class="grid gap-8 lg:grid-cols-2">
    {/* 13 Compliance and Safety Rules */}
    <div class="rounded-2xl border border-gray-700 bg-slate-900 dark:bg-black p-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="flex w-10 h-10 shrink-0 items-center justify-center rounded-lg bg-red-500/20 border border-red-500/30">
          <Icon name="tabler:shield-check" class="w-5 h-5 text-red-400" />
        </span>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-red-400">Required</p>
          <h3 class="text-lg font-bold text-white">13 Compliance and Safety Rules</h3>
        </div>
      </div>
      <p class="text-sm text-gray-400 mb-6">These must pass on every schedule. If any fail, the draft is flagged before delivery.</p>
      <ul class="space-y-3">
        {complianceRules.map((rule) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 shrink-0 flex w-5 h-5 items-center justify-center rounded-full bg-red-500/20 border border-red-500/40">
              <Icon name="tabler:check" class="w-3 h-3 text-red-400" />
            </span>
            <span class="text-sm text-gray-300">{rule}</span>
          </li>
        ))}
      </ul>
    </div>

    {/* 8 Fairness Goals */}
    <div class="rounded-2xl border border-gray-700 bg-slate-900 dark:bg-black p-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="flex w-10 h-10 shrink-0 items-center justify-center rounded-lg bg-blue-500/20 border border-blue-500/30">
          <Icon name="tabler:star" class="w-5 h-5 text-blue-400" />
        </span>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-400">Optimized</p>
          <h3 class="text-lg font-bold text-white">8 Fairness and Preference Goals</h3>
        </div>
      </div>
      <p class="text-sm text-gray-400 mb-6">These are actively optimized on every draft. Flags are surfaced so you can choose the best trade-off.</p>
      <ul class="space-y-3">
        {fairnessGoals.map((goal) => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 shrink-0 flex w-5 h-5 items-center justify-center rounded-full bg-blue-500/20 border border-blue-500/40">
              <Icon name="tabler:star-filled" class="w-3 h-3 text-blue-400" />
            </span>
            <span class="text-sm text-gray-300">{goal}</span>
          </li>
        ))}
      </ul>
      <div class="mt-6 rounded-xl border border-blue-700/40 bg-blue-900/20 p-4">
        <p class="text-sm text-blue-300">Every fairness flag is explained. You see which trade-off was made and why, so you can approve or adjust with full context.</p>
      </div>
    </div>
  </div>
</WidgetWrapper>
