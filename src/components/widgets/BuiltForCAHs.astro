---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { Widget } from '~/types';

type Props = Widget;

const { id, isDark = false, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props;

const title = 'Built for Critical Access Hospitals in Texas';

const scenarios = [
  {
    title: 'Lean Staffing Reality',
    description: 'Where a single call-out can break coverage for the entire unit.',
  },
  {
    title: '24/7 Emergency Coverage',
    description: 'Maintaining the ED "ready-state" while balancing small bed counts.',
  },
  {
    title: 'Rural Constraints',
    description: 'Distance makes "just add staff" unrealistic. We optimize what you have.',
  },
];

const commonScenarios = {
  title: 'Common CAH Scenarios We Handle',
  items: [
    '7 PM call-out → System auto-finds top 3 replacements with reasons',
    'Leave approved → Affected shifts get replacement candidates automatically',
    'Weekend fairness complaints → No nurse should work more than 3 weekends per 6-week period',
    'Junior-heavy shift → Competency pairing rules require a Level 4+ nurse on the shift',
    'PRN scheduling chaos → Only scheduled on days they marked available',
    'Holiday assignment disputes → Fair rotation tracked annually across the team',
    'Who approved what? → Full audit trail of every change',
  ],
};
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl ${classes?.container ?? ''}`} bg={bg}>
  <div class="text-center mb-14">
    <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-primary">Who we serve</p>
    <Headline title={title} classes={{ title: 'text-3xl sm:text-4xl' }} />
  </div>

  <div class="grid gap-10 md:grid-cols-3 mb-16">
    {
      scenarios.map((scenario) => (
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-blue-50 dark:bg-blue-950">
            <span class="h-2 w-2 rounded-full bg-primary" />
          </div>
          <h3 class="text-xl font-bold">{scenario.title}</h3>
          <p class="mt-3 leading-relaxed text-muted">{scenario.description}</p>
        </div>
      ))
    }
  </div>

  <div
    class="mx-auto max-w-4xl rounded-2xl border border-blue-100 dark:border-blue-900 bg-blue-50 dark:bg-blue-950/30 p-8 md:p-10"
  >
    <h3 class="text-xl font-bold">{commonScenarios.title}</h3>
    <ul class="mt-6 grid gap-4 md:grid-cols-2">
      {
        commonScenarios.items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-primary" />
            <span class="text-gray-700 dark:text-gray-300">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</WidgetWrapper>
