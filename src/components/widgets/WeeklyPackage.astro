---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { Widget } from '~/types';

type Props = Widget;

const { id, isDark = false, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props;

const title = 'Your Schedule Package';
const subtitle =
  'Delivered every Thursday 3pm (or your chosen cadence). No more spreadsheet chaos. Just post and hand off.';

const deliverables = [
  {
    title: 'Schedule PDF',
    description: 'Post-ready, cleanly formatted for the unit board.',
  },
  {
    title: 'Excel Workbook',
    description: 'Final schedule + exceptions log + risk flags. Export → Edit → Re-import anytime.',
  },
  {
    title: 'Schedule Options',
    description: 'Multiple drafts scored by coverage, fairness, and cost. You pick the best fit.',
  },
  {
    title: 'Manager Summary',
    description: 'What changed, pending approvals, and budget impact.',
  },
  {
    title: 'Audit Trail',
    description: 'Complete history of every change: who, what, when. For compliance.',
  },
];
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl ${classes?.container ?? ''}`} bg={bg}>
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <Headline
        title={title}
        subtitle={subtitle}
        classes={{ title: 'text-3xl sm:text-4xl text-left', subtitle: 'text-lg text-left' }}
      />

      <div class="mt-10 space-y-6">
        {
          deliverables.map((item) => (
            <div class="border-l-4 border-primary pl-4">
              <h3 class="font-semibold">{item.title}</h3>
              <p class="mt-1 text-muted">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    {/* Schedule PDF mockup */}
    <div
      class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 shadow-xl overflow-hidden"
    >
      {/* PDF header */}
      <div class="bg-primary px-5 py-4 flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold text-blue-200 uppercase tracking-wider">CAH Medical-Surgical Unit</p>
          <p class="text-sm font-bold text-white mt-0.5">Week of Jun 2–8, 2025</p>
        </div>
        <span class="rounded-full bg-white/20 border border-white/30 px-3 py-1 text-xs font-semibold text-white"
          >PDF Ready</span
        >
      </div>

      {/* Schedule grid */}
      <div class="px-5 pt-4 pb-2">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b-2 border-gray-200 dark:border-gray-700">
              <th class="text-left pb-2 text-muted font-semibold uppercase tracking-wide w-20">Date</th>
              <th class="text-left pb-2 text-muted font-semibold uppercase tracking-wide">Day 07–19</th>
              <th class="text-left pb-2 text-muted font-semibold uppercase tracking-wide">Night 19–07</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            <tr>
              <td class="py-2.5 font-semibold">Mon Jun 2</td>
              <td class="py-2.5">
                <p>Maria G. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">Emily D. · Lisa A.</p>
              </td>
              <td class="py-2.5">
                <p>James W. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">Michael B.</p>
              </td>
            </tr>
            <tr>
              <td class="py-2.5 font-semibold">Tue Jun 3</td>
              <td class="py-2.5">
                <p>Maria G. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">Ashley J. · Amanda W.</p>
              </td>
              <td class="py-2.5">
                <p>James W. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">Christopher A.</p>
              </td>
            </tr>
            <tr>
              <td class="py-2.5 font-semibold">Thu Jun 5</td>
              <td class="py-2.5">
                <p>Maria G. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">
                  Ashley J. ·
                  <span class="inline-flex items-center gap-0.5">
                    Elizabeth M.
                    <span class="rounded bg-red-100 px-1 text-[10px] font-bold text-red-600">OT</span>
                  </span>
                </p>
              </td>
              <td class="py-2.5">
                <p>James W. <span class="text-primary font-medium">Charge</span></p>
                <p class="text-muted">Jessica R. · Daniel H.</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      {/* Footer */}
      <div
        class="flex items-center justify-between border-t border-gray-200 dark:border-gray-700 px-5 py-3 bg-gray-50 dark:bg-slate-900"
      >
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-1.5">
            <span class="h-2 w-2 rounded-full bg-green-500"></span>
            <span class="text-xs text-muted">21 rules validated · 0 violations</span>
          </div>
          <span class="text-xs text-muted">·</span>
          <span class="text-xs text-muted">3 fairness flags reviewed</span>
        </div>
        <span class="text-xs font-medium text-primary">Thu 8:04 AM</span>
      </div>
    </div>
  </div>
</WidgetWrapper>
