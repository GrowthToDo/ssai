---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';
import ShowcaseShiftStatus from './ShowcaseShiftStatus.svelte';
import type { Widget } from '~/types';

type Props = Widget;

const { id, isDark = true, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props;

const title = 'Every schedule is compliant before it posts.';
const subtitle =
  '13 rules protect safe staffing on every schedule. 8 more track fairness for your team. All checked automatically. Nothing slips through.';
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl ${classes?.container ?? ''}`} bg={bg}>
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center">

    <!-- Left: existing text content -->
    <div class="text-center lg:text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-blue-400">What we check every cycle</p>
      <div class="mb-2 text-8xl font-black text-primary sm:text-9xl leading-none">21</div>
      <p class="text-sm font-medium text-gray-400 mb-4">rules checked on every schedule</p>
      <Headline
        title={title}
        subtitle={subtitle}
        classes={{
          title: 'text-3xl sm:text-4xl text-white',
          subtitle: 'text-lg text-gray-400',
        }}
      />
      <a
        href="/how-it-works"
        class="mt-8 inline-flex items-center gap-2 text-primary font-medium hover:text-secondary transition-colors duration-200"
      >
        See every rule we check
        <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    <!-- Right: animated shift status widget -->
    <div class="relative">
      <ShowcaseShiftStatus client:visible />
    </div>

  </div>
</WidgetWrapper>
