---
import ShowcaseGenerateSchedule from './ShowcaseGenerateSchedule.svelte';
---

<section class="bg-page">
  <div class="mx-auto max-w-7xl px-4 pb-10 pt-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">

      <!-- Left: text -->
      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-primary">AI Scheduling Engine</p>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          From blank grid to full schedule in seconds.
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
          The engine checks 13 safety rules and 8 fairness rules as it fills every slot — automatically.
        </p>
        <a
          href="/pilot"
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-secondary"
        >
          Join the pilot →
        </a>
      </div>

      <!-- Right: animated widget -->
      <ShowcaseGenerateSchedule client:visible />

    </div>
  </div>
</section>
