---
// Product interface showcase - shows the actual CAH Scheduler interface
---

<section class="bg-page">
  <div class="mx-auto max-w-7xl px-4 pb-10 sm:px-6 lg:px-8">
    {/* Hero Visual — realistic schedule + compliance panels */}
    <div class="relative m-auto w-full pt-4 sm:w-[95%]">
      <div class="pointer-events-none absolute inset-x-0 -bottom-2 z-10 hidden h-20 w-full bg-gradient-to-b from-transparent via-white dark:via-slate-950 to-white dark:to-slate-950 sm:block">
      </div>

      <div class="rounded-xl ring-1 ring-gray-200 dark:ring-white/10 shadow-2xl bg-white dark:bg-slate-900 overflow-hidden">

        {/* Window chrome */}
        <div class="flex items-center gap-2 px-4 py-3 bg-gray-100 dark:bg-slate-800/80 border-b border-gray-200 dark:border-slate-700/50">
          <span class="h-3 w-3 rounded-full bg-gray-400 dark:bg-slate-600"></span>
          <span class="h-3 w-3 rounded-full bg-gray-400 dark:bg-slate-600"></span>
          <span class="h-3 w-3 rounded-full bg-gray-400 dark:bg-slate-600"></span>
          <span class="ml-3 text-xs text-muted font-mono">CAH Scheduler: Week of Jun 2-8</span>
          <div class="ml-auto flex items-center gap-2">
            <span class="hidden sm:inline-flex items-center gap-1.5 rounded-full bg-primary/25 border border-primary/50 px-2.5 py-0.5 text-xs font-semibold text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              17 fairness flags
            </span>
            <span class="hidden sm:inline-flex items-center gap-1.5 rounded-full bg-primary/25 border border-primary/50 px-2.5 py-0.5 text-xs font-semibold text-primary">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              0 compliance violations
            </span>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 min-h-0">

          {/* ── LEFT: Schedule Grid (3 cols) ── */}
          <div class="lg:col-span-3 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-slate-700/50 overflow-hidden">

            {/* Column headers */}
            <div class="grid grid-cols-[6rem_1fr_1fr] gap-0 border-b border-gray-200 dark:border-slate-700/50 bg-gray-50 dark:bg-slate-800/40 px-3 py-2 text-xs font-semibold text-muted uppercase tracking-wider">
              <span>Date</span>
              <span>Day Shift (07:00–19:00)</span>
              <span>Night Shift (19:00–07:00)</span>
            </div>

            {/* Row 1 — Mon Jun 2 */}
            <div class="grid grid-cols-[6rem_1fr_1fr] gap-0 border-b border-gray-100 dark:border-slate-700/30 px-3 py-3">
              <div class="flex flex-col justify-start pt-0.5">
                <span class="text-xs font-semibold">Mon, Jun 2</span>
              </div>
              {/* Day shift — compliant */}
              <div class="mr-2 rounded-lg border border-primary/40 bg-primary/10 p-2">
                <p class="text-xs text-muted mb-1.5">4/4 staff</p>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Maria G.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Jennifer W.</span><span class="text-muted text-[10px]">CNA</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Lisa A.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Emily D.</span><span class="text-muted text-[10px]">RN</span></li>
                </ul>
              </div>
              {/* Night shift — compliant */}
              <div class="rounded-lg border border-primary/40 bg-primary/10 p-2">
                <p class="text-xs text-muted mb-1.5">3/3 staff</p>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">James W.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Michael B.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Daniel H.</span><span class="text-muted text-[10px]">CNA</span></li>
                </ul>
              </div>
            </div>

            {/* Row 2 — Tue Jun 3 */}
            <div class="grid grid-cols-[6rem_1fr_1fr] gap-0 border-b border-gray-100 dark:border-slate-700/30 px-3 py-3">
              <div class="flex flex-col justify-start pt-0.5">
                <span class="text-xs font-semibold">Tue, Jun 3</span>
              </div>
              {/* Day shift — compliant */}
              <div class="mr-2 rounded-lg border border-primary/40 bg-primary/10 p-2">
                <p class="text-xs text-muted mb-1.5">4/4 staff</p>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Maria G.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Emily D.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Amanda W.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Ashley J.</span><span class="text-muted text-[10px]">RN</span></li>
                </ul>
              </div>
              {/* Night shift — compliant */}
              <div class="rounded-lg border border-primary/40 bg-primary/10 p-2">
                <p class="text-xs text-muted mb-1.5">3/3 staff</p>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">James W.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Christopher A.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Stephanie S.</span><span class="text-muted text-[10px]">CNA</span></li>
                </ul>
              </div>
            </div>

            {/* Row 3 — Thu Jun 5 — soft violation */}
            <div class="grid grid-cols-[6rem_1fr_1fr] gap-0 px-3 py-3">
              <div class="flex flex-col justify-start pt-0.5">
                <span class="text-xs font-semibold">Thu, Jun 5</span>
              </div>
              {/* Day shift — soft violation (OT) */}
              <div class="relative mr-2 rounded-lg border border-primary/40 bg-primary/10 p-2">
                <div class="flex items-center justify-between mb-1.5">
                  <p class="text-xs text-muted">4/4 staff</p>
                  <span class="rounded-full bg-primary/20 border border-primary/30 px-1.5 py-0.5 text-[10px] font-semibold text-primary">1 flag</span>
                </div>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Maria G.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Ashley J.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Amanda W.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs">
                    <span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span>
                    <span class="text-default">Elizabeth M.</span>
                    <span class="text-muted text-[10px]">RN</span>
                    <span class="ml-1 rounded-sm bg-primary/20 border border-primary/40 px-1 py-0.5 text-[10px] font-bold text-primary leading-none">OT</span>
                  </li>
                </ul>
              </div>
              {/* Night shift — compliant */}
              <div class="rounded-lg border border-primary/40 bg-primary/10 p-2">
                <p class="text-xs text-muted mb-1.5">3/3 staff</p>
                <ul class="space-y-1">
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">James W.</span><span class="text-muted text-[10px]">RN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Jessica R.</span><span class="text-muted text-[10px]">LPN</span></li>
                  <li class="flex items-center gap-1.5 text-xs"><span class="h-1.5 w-1.5 rounded-full bg-gray-400 shrink-0"></span><span class="text-default">Daniel H.</span><span class="text-muted text-[10px]">CNA</span></li>
                </ul>
              </div>
            </div>

          </div>

          {/* ── RIGHT: Soft Violations Panel (2 cols) ── */}
          <div class="lg:col-span-2 flex flex-col">

            {/* Violations header */}
            <div class="border-b border-gray-200 dark:border-slate-700/50 bg-primary/10 px-4 py-3">
              <p class="text-xs font-bold text-primary">Fairness Flags: 17 total</p>
              <p class="text-xs text-muted mt-0.5">Schedule quality check</p>
            </div>

            {/* By rule */}
            <div class="border-b border-gray-200 dark:border-slate-700/50 px-4 py-3">
              <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">By rule</p>
              <div class="space-y-1.5">
                <div class="flex items-center justify-between text-xs">
                  <span class="text-default">Overtime</span>
                  <span class="rounded-full bg-gray-200 dark:bg-slate-700 px-2 py-0.5 text-default font-semibold">8</span>
                </div>
                <div class="flex items-center justify-between text-xs">
                  <span class="text-default">Staff Preference Match</span>
                  <span class="rounded-full bg-gray-200 dark:bg-slate-700 px-2 py-0.5 text-default font-semibold">8</span>
                </div>
                <div class="flex items-center justify-between text-xs">
                  <span class="text-default">Extra Hours Above FTE</span>
                  <span class="rounded-full bg-gray-200 dark:bg-slate-700 px-2 py-0.5 text-default font-semibold">1</span>
                </div>
              </div>
            </div>

            {/* Affected staff */}
            <div class="flex-1 px-4 py-3 overflow-hidden">
              <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">Affected staff</p>
              <div class="space-y-2.5">
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-default">Elizabeth Mitchell</span>
                    <span class="text-xs text-primary font-semibold">5 flags</span>
                  </div>
                  <p class="text-xs text-muted mt-0.5">Extra Hours Above FTE · Staff Preference Match</p>
                </div>
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-default">James Wilson</span>
                    <span class="text-xs text-primary font-semibold">3 flags</span>
                  </div>
                  <p class="text-xs text-muted mt-0.5">Overtime · Staff Preference Match</p>
                </div>
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-default">Maria Garcia</span>
                    <span class="text-xs text-primary font-semibold">2 flags</span>
                  </div>
                  <p class="text-xs text-muted mt-0.5">Overtime · Staff Preference Match</p>
                </div>
                <div>
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-default">Amanda Walker</span>
                    <span class="text-xs text-primary font-semibold">1 flag</span>
                  </div>
                  <p class="text-xs text-muted mt-0.5">Overtime</p>
                </div>
              </div>
            </div>

            {/* Delivery footer */}
            <div class="border-t border-gray-200 dark:border-slate-700/50 bg-primary/10 px-4 py-3 space-y-1.5">
              <p class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">Thursday delivery</p>
              <div class="flex items-center gap-2 text-xs">
                <svg class="h-3.5 w-3.5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-default">schedule-week-jun2.pdf</span>
                <span class="ml-auto text-primary font-medium">Ready</span>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <svg class="h-3.5 w-3.5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-default">schedule-week-jun2.xlsx</span>
                <span class="ml-auto text-primary font-medium">Ready</span>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <svg class="h-3.5 w-3.5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-default">Manager summary</span>
                <span class="ml-auto text-primary font-medium">Ready</span>
              </div>
            </div>

          </div>

        </div>

        {/* Status bar */}
        <div class="flex items-center justify-between px-5 py-2.5 bg-gray-100 dark:bg-slate-800/60 border-t border-gray-200 dark:border-slate-700/50">
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-primary"></span>
              <span class="text-xs text-muted">13 compliance rules, all passed</span>
            </div>
            <div class="hidden sm:flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-primary"></span>
              <span class="text-xs text-muted">17 fairness flags, use Fairness variant to reduce</span>
            </div>
          </div>
          <span class="text-xs text-muted">Generated Thu 8:04 AM</span>
        </div>

      </div>
    </div>
  </div>
</section>
