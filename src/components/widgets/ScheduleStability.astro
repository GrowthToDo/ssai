---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import type { Widget } from '~/types';

type Props = Widget;

const { id, isDark = true, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props;

const title = 'The schedule posts itself. You just approve.';
const subtitle = "We don't just fill slots. We manage the integrity of the unit.";

const metrics = [
  {
    title: 'On Time, Every Time',
    description: 'Schedule posted by Thursday 3pm, before the weekend team needs to know.',
  },
  {
    title: 'Zero Coverage Gaps',
    description: 'Gaps caught before staff see the board, not after.',
  },
  {
    title: 'Call-Outs Handled',
    description: 'Replacements surface automatically. Call-outs stop coming to your phone.',
  },
  {
    title: 'OT Flagged Early',
    description: 'Overtime risk surfaced before it hits payroll.',
  },
  {
    title: 'Audit-Ready',
    description: 'Staffing committee packet ready in one click, always current.',
  },
];
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl ${classes?.container ?? ''}`} bg={bg}>
  <div class="mx-auto max-w-3xl text-center mb-12">
    <Headline title={title} subtitle={subtitle} classes={{ title: 'text-3xl sm:text-4xl', subtitle: 'text-lg' }} />
  </div>

  <div class="grid gap-8 md:grid-cols-5">
    {
      metrics.map((metric) => (
        <div class="text-center">
          <h3 class="text-lg font-bold text-white">{metric.title}</h3>
          <p class="mt-2 text-sm text-gray-400">{metric.description}</p>
        </div>
      ))
    }
  </div>
</WidgetWrapper>
