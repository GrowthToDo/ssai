# Enforce LF line endings for all text files
# Prevents CRLF/LF mismatch between Windows dev and Linux CI

* text=auto eol=lf

# Explicitly LF for code and content files
*.astro text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
